---
import BaseLayout from '../layouts/BaseLayout.astro';

// Bible books organized by section
const sections = [
  {
    id: 'pentateuch',
    title: 'The Pentateuch',
    subtitle: 'The Five Books of Moses',
    books: ['Genesis', 'Exodus', 'Leviticus', 'Numbers', 'Deuteronomy']
  },
  {
    id: 'history',
    title: 'Historical Books',
    subtitle: 'From Joshua to Esther',
    books: ['Joshua', 'Judges', 'Ruth', '1 Samuel', '2 Samuel', '1 Kings', '2 Kings', '1 Chronicles', '2 Chronicles', 'Ezra', 'Nehemiah', 'Esther']
  },
  {
    id: 'wisdom',
    title: 'Wisdom Literature',
    subtitle: 'Poetry and Wisdom',
    books: ['Job', 'Psalms', 'Proverbs', 'Ecclesiastes', 'Song of Solomon']
  },
  {
    id: 'prophets',
    title: 'The Prophets',
    subtitle: 'Major and Minor Prophets',
    books: ['Isaiah', 'Jeremiah', 'Lamentations', 'Ezekiel', 'Daniel', 'Hosea', 'Joel', 'Amos', 'Obadiah', 'Jonah', 'Micah', 'Nahum', 'Habakkuk', 'Zephaniah', 'Haggai', 'Zechariah', 'Malachi']
  },
  {
    id: 'gospels',
    title: 'The Gospels',
    subtitle: 'The Life of Jesus',
    books: ['Matthew', 'Mark', 'Luke', 'John']
  },
  {
    id: 'acts-letters',
    title: 'Acts & Letters',
    subtitle: 'The Early Church',
    books: ['Acts', 'Romans', '1 Corinthians', '2 Corinthians', 'Galatians', 'Ephesians', 'Philippians', 'Colossians', '1 Thessalonians', '2 Thessalonians', '1 Timothy', '2 Timothy', 'Titus', 'Philemon', 'Hebrews', 'James', '1 Peter', '2 Peter', '1 John', '2 John', '3 John', 'Jude', 'Revelation']
  },
  {
    id: 'apocrypha',
    title: 'The Apocrypha',
    subtitle: 'Deuterocanonical Books',
    books: ['Tobit', 'Judith', 'Additions to Esther', 'Wisdom', 'Sirach', 'Baruch', '1 Maccabees', '2 Maccabees', '1 Esdras', '2 Esdras', 'Prayer of Manasseh', 'Psalm 151', '3 Maccabees', '4 Maccabees']
  }
];

// Color palette for book cards (cycles through)
const colors = [
  '#2D4A3E', // Deep forest
  '#1A2A3A', // Warm navy
  '#6A1F1F', // Burgundy
  '#4A2040', // Plum
  '#3B2A1A', // Espresso
  '#2A4A50', // Slate teal
  '#5A1A2A', // Oxblood
  '#3A3520', // Charcoal gold
  '#1A1A3A', // Midnight
  '#6A3A1A', // Sienna
];

let colorIndex = 0;
function getNextColor() {
  const color = colors[colorIndex % colors.length];
  colorIndex++;
  return color;
}
---

<BaseLayout title="Library — The Table Bible" description="Browse all 81 books of the World English Bible. Watch chapters, full books, or volume collections.">
  <section class="library-hero">
    <div class="container">
      <h1>Library</h1>
      <p>Browse the entire World English Bible — 81 books, over 1,400 chapters</p>
    </div>
  </section>
  
  <section class="library-nav">
    <div class="container">
      <nav class="section-tabs" aria-label="Bible sections">
        {sections.map(section => (
          <a href={`#${section.id}`} class="section-tab">{section.title}</a>
        ))}
      </nav>
    </div>
  </section>
  
  <div class="library-content container">
    {sections.map(section => (
      <section id={section.id} class="book-section">
        <div class="section-header">
          <h2>{section.title}</h2>
          <p>{section.subtitle}</p>
        </div>
        
        <div class="book-grid">
          {section.books.map(book => {
            const color = getNextColor();
            return (
              <a href={`https://youtube.com/@TheTableBible`} target="_blank" rel="noopener" class="book-card" style={`--card-color: ${color}`}>
                <div class="book-card-bg"></div>
                <div class="book-card-content">
                  <h3>{book}</h3>
                  <span class="book-status">Coming Soon</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>
  
  <section class="library-cta">
    <div class="container container-narrow">
      <div class="cta-card">
        <h2>Subscribe for Updates</h2>
        <p>Be the first to know when new chapters are uploaded</p>
        <a href="https://youtube.com/@TheTableBible?sub_confirmation=1" target="_blank" rel="noopener" class="btn btn-primary">
          Subscribe on YouTube
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Library Hero ────────────────────────────────────────────────── */
  .library-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    text-align: center;
    background: var(--bg-secondary);
  }
  
  .library-hero h1 {
    margin-bottom: var(--space-md);
  }
  
  .library-hero p {
    color: var(--text-muted);
    font-size: 1.125rem;
  }
  
  /* ── Section Navigation ──────────────────────────────────────────── */
  .library-nav {
    position: sticky;
    top: 72px;
    z-index: 50;
    background: rgba(26, 22, 18, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(201, 168, 106, 0.1);
    padding: var(--space-md) 0;
  }
  
  .section-tabs {
    display: flex;
    gap: var(--space-sm);
    overflow-x: auto;
    padding-bottom: var(--space-xs);
    scrollbar-width: thin;
    scrollbar-color: var(--gold-light) transparent;
  }
  
  .section-tabs::-webkit-scrollbar {
    height: 4px;
  }
  
  .section-tabs::-webkit-scrollbar-thumb {
    background: var(--gold-light);
    border-radius: 2px;
  }
  
  .section-tab {
    flex-shrink: 0;
    padding: var(--space-sm) var(--space-lg);
    font-size: 0.875rem;
    color: var(--text-muted);
    border: 1px solid rgba(201, 168, 106, 0.2);
    border-radius: var(--radius-xl);
    white-space: nowrap;
    transition: all var(--transition-fast);
  }
  
  .section-tab:hover {
    color: var(--cream);
    border-color: var(--gold-light);
    background: rgba(201, 168, 106, 0.1);
  }
  
  /* ── Library Content ─────────────────────────────────────────────── */
  .library-content {
    padding: var(--space-3xl) var(--space-lg);
  }
  
  .book-section {
    margin-bottom: var(--space-4xl);
    scroll-margin-top: 160px;
  }
  
  .book-section .section-header {
    margin-bottom: var(--space-xl);
  }
  
  .book-section .section-header h2 {
    margin-bottom: var(--space-xs);
  }
  
  .book-section .section-header p {
    color: var(--gold-light);
    font-size: 1rem;
  }
  
  /* ── Book Grid ───────────────────────────────────────────────────── */
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-md);
  }
  
  .book-card {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: transform var(--transition-base);
  }
  
  .book-card:hover {
    transform: translateY(-4px) scale(1.02);
  }
  
  .book-card-bg {
    position: absolute;
    inset: 0;
    background: var(--card-color);
    opacity: 0.85;
  }
  
  .book-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.6) 100%);
    z-index: 1;
  }
  
  .book-card-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-md);
  }
  
  .book-card h3 {
    font-size: 1rem;
    font-weight: 400;
    color: var(--cream);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
  }
  
  .book-status {
    font-size: 0.75rem;
    color: var(--gold-light);
    opacity: 0.8;
  }
  
  /* ── CTA Section ─────────────────────────────────────────────────── */
  .library-cta {
    padding: var(--space-3xl) 0 var(--space-4xl);
    background: var(--bg-secondary);
  }
  
  .cta-card {
    text-align: center;
    padding: var(--space-3xl);
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(201, 168, 106, 0.1);
  }
  
  .cta-card h2 {
    margin-bottom: var(--space-md);
  }
  
  .cta-card p {
    color: var(--text-muted);
    margin-bottom: var(--space-xl);
  }
  
  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .book-grid {
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    }
    
    .library-nav {
      top: 56px;
    }
    
    .book-section {
      scroll-margin-top: 140px;
    }
  }
</style>
