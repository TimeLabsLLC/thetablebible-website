---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://thetablebible.org/watch/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Library", "item": "https://thetablebible.org/library/" },
    { "@type": "ListItem", "position": 2, "name": "Watch", "item": "https://thetablebible.org/watch/" },
  ],
};
---

<BaseLayout title="Watch — The Table Bible" description="Watch Bible chapters with word-by-word highlighted text." jsonLd={breadcrumbLd} robots="noindex,follow">
  <div class="watch-page container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/library/">Library</a>
      <span class="separator">›</span>
      <span class="current" id="crumb-title">Watch</span>
    </nav>

    <div class="player-wrapper">
      <div class="player-frame" id="player-frame">
        <p class="player-loading">Loading video…</p>
      </div>
    </div>

    <div class="watch-sequence" id="watch-sequence" hidden>
      <h2 id="watch-sequence-title">Chapter queue</h2>
      <p id="watch-sequence-copy"></p>
    </div>

    <div class="watch-actions">
      <button class="btn btn-secondary" id="back-btn" onclick="history.back()">← Back</button>
    </div>
  </div>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const videoId = params.get('v');
  const listType = params.get('listType');
  const idsParam = params.get('ids');
  const bookName = params.get('book');
  const startChapter = params.get('start');
  const frame = document.getElementById('player-frame')!;
  const sequencePanel = document.getElementById('watch-sequence');
  const sequenceCopy = document.getElementById('watch-sequence-copy');
  const sequenceTitle = document.getElementById('watch-sequence-title');

  const parsedIds = (idsParam || '')
    .split(',')
    .map(id => id.trim())
    .filter(id => /^[a-zA-Z0-9_-]{11}$/.test(id));

  const isSequence = listType === 'sequence' && parsedIds.length > 1 && videoId === parsedIds[0];

  if (videoId && /^[a-zA-Z0-9_-]{11}$/.test(videoId)) {
    const embedParams = new URLSearchParams({ autoplay: '1' });
    if (isSequence) {
      embedParams.set('playlist', parsedIds.slice(1).join(','));
    }

    frame.innerHTML = `<iframe
      src="https://www.youtube-nocookie.com/embed/${videoId}?${embedParams.toString()}"
      title="The Table Bible"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>`;

    if (isSequence && sequencePanel && sequenceCopy && sequenceTitle) {
      sequenceTitle.textContent = bookName ? `${bookName} chapter queue` : 'Chapter queue';
      sequenceCopy.textContent = startChapter
        ? `Starting at chapter ${startChapter}. ${parsedIds.length} videos will play in order.`
        : `${parsedIds.length} videos will play in order.`;
      sequencePanel.hidden = false;
    }
  } else {
    frame.innerHTML = '<p class="player-error">Video not found. <a href="/library/">Return to Library</a></p>';
  }
</script>

<style>
  .watch-page {
    padding: var(--space-xl) var(--space-lg) var(--space-4xl);
    max-width: 960px;
  }

  .breadcrumb {
    margin-bottom: var(--space-xl);
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  .breadcrumb a { color: var(--gold-light); }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .separator { margin: 0 var(--space-sm); color: var(--text-muted); }
  .breadcrumb .current { color: var(--cream); }

  .player-wrapper {
    margin-bottom: var(--space-xl);
  }
  .player-frame {
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .player-frame iframe {
    width: 100%;
    height: 100%;
  }
  .player-loading, .player-error {
    color: var(--text-muted);
    text-align: center;
    padding: var(--space-xl);
  }
  .player-error a { color: var(--gold-light); }

  .watch-actions {
    text-align: center;
  }

  .watch-sequence {
    margin: 0 0 var(--space-xl);
    padding: var(--space-lg);
    border: 1px solid rgba(201, 168, 106, 0.16);
    border-radius: var(--radius-lg);
    background: rgba(42, 35, 30, 0.72);
    text-align: center;
  }

  .watch-sequence h2 {
    margin-bottom: var(--space-sm);
    font-size: 1.1rem;
    color: var(--gold-light);
  }

  .watch-sequence p {
    margin: 0;
    color: var(--text-muted);
  }
</style>
