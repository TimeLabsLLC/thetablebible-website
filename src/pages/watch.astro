---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://thetablebible.org/watch/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Library", "item": "https://thetablebible.org/library/" },
    { "@type": "ListItem", "position": 2, "name": "Watch", "item": "https://thetablebible.org/watch/" },
  ],
};
---

<BaseLayout title="Watch — The Table Bible" description="Watch Bible chapters with word-by-word highlighted text." jsonLd={breadcrumbLd} robots="noindex,follow">
  <div class="mx-auto max-w-[960px] px-4 pt-6 pb-16">
    <nav class="mb-6 text-sm text-charcoal-muted" aria-label="Breadcrumb">
      <a href="/library/" class="text-accent hover:underline">Library</a>
      <span class="mx-1.5">›</span>
      <span id="crumb-title">Watch</span>
    </nav>

    <div class="mb-6">
      <div class="player-frame aspect-video w-full rounded-lg overflow-hidden bg-black flex items-center justify-center" id="player-frame">
        <p class="text-charcoal-muted text-center p-6">Loading video…</p>
      </div>
    </div>

    <div class="mb-6 p-4 border border-cream-300 rounded-xl bg-cream-200 text-center" id="watch-sequence" hidden>
      <h2 class="mb-1 text-lg text-gold-dark" id="watch-sequence-title">Chapter queue</h2>
      <p class="text-charcoal-muted" id="watch-sequence-copy"></p>
    </div>

    <div class="text-center">
      <button class="btn btn-secondary" id="back-btn" onclick="history.back()">← Back</button>
    </div>
  </div>
</BaseLayout>

<style>
  .player-frame iframe { width: 100%; height: 100%; }
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  const videoId = params.get('v');
  const listType = params.get('listType');
  const idsParam = params.get('ids');
  const bookName = params.get('book');
  const startChapter = params.get('start');
  const frame = document.getElementById('player-frame')!;
  const sequencePanel = document.getElementById('watch-sequence');
  const sequenceCopy = document.getElementById('watch-sequence-copy');
  const sequenceTitle = document.getElementById('watch-sequence-title');

  const parsedIds = (idsParam || '')
    .split(',')
    .map(id => id.trim())
    .filter(id => /^[a-zA-Z0-9_-]{11}$/.test(id));

  const isSequence = listType === 'sequence' && parsedIds.length > 1 && videoId === parsedIds[0];

  if (videoId && /^[a-zA-Z0-9_-]{11}$/.test(videoId)) {
    const embedParams = new URLSearchParams({ autoplay: '1' });
    if (isSequence) {
      embedParams.set('playlist', parsedIds.slice(1).join(','));
    }

    frame.innerHTML = `<iframe
      src="https://www.youtube-nocookie.com/embed/${videoId}?${embedParams.toString()}"
      title="The Table Bible"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>`;

    if (isSequence && sequencePanel && sequenceCopy && sequenceTitle) {
      sequenceTitle.textContent = bookName ? `${bookName} chapter queue` : 'Chapter queue';
      sequenceCopy.textContent = startChapter
        ? `Starting at chapter ${startChapter}. ${parsedIds.length} videos will play in order.`
        : `${parsedIds.length} videos will play in order.`;
      sequencePanel.hidden = false;
    }
  } else {
    frame.innerHTML = '<p class="player-error">Video not found. <a href="/library/">Return to Library</a></p>';
  }
</script>

