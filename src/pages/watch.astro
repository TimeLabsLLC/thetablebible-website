---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Watch — The Table Bible" description="Watch Bible chapters with word-by-word highlighted text.">
  <div class="watch-page container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/library/">Library</a>
      <span class="separator">›</span>
      <span class="current" id="crumb-title">Watch</span>
    </nav>

    <div class="player-wrapper">
      <div class="player-frame" id="player-frame">
        <p class="player-loading">Loading video…</p>
      </div>
    </div>

    <div class="watch-actions">
      <button class="btn btn-secondary" id="back-btn" onclick="history.back()">← Back</button>
    </div>
  </div>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const videoId = params.get('v');
  const frame = document.getElementById('player-frame')!;

  if (videoId && /^[a-zA-Z0-9_-]{11}$/.test(videoId)) {
    frame.innerHTML = `<iframe
      src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1"
      title="The Table Bible"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>`;
  } else {
    frame.innerHTML = '<p class="player-error">Video not found. <a href="/library/">Return to Library</a></p>';
  }
</script>

<style>
  .watch-page {
    padding: var(--space-xl) var(--space-lg) var(--space-4xl);
    max-width: 960px;
  }

  .breadcrumb {
    margin-bottom: var(--space-xl);
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  .breadcrumb a { color: var(--gold-light); }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .separator { margin: 0 var(--space-sm); color: var(--text-muted); }
  .breadcrumb .current { color: var(--cream); }

  .player-wrapper {
    margin-bottom: var(--space-xl);
  }
  .player-frame {
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .player-frame iframe {
    width: 100%;
    height: 100%;
  }
  .player-loading, .player-error {
    color: var(--text-muted);
    text-align: center;
    padding: var(--space-xl);
  }
  .player-error a { color: var(--gold-light); }

  .watch-actions {
    text-align: center;
  }
</style>
