---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllBooksWithSections, getChapterThumbUrl, getChapterUrl, getChapterVideoId, getFullBookVideoId, getPlayAllUrl, getPlayableChapterSequence, getVideoUploadDate } from '../../../utils/library';

export function getStaticPaths() {
  return getAllBooksWithSections().flatMap(({ book, sectionTitle }) =>
    Array.from({ length: book.chapters }, (_, index) => {
      const chapter = index + 1;
      return {
        params: {
          book: book.slug,
          chapter: String(chapter),
        },
        props: {
          book,
          sectionTitle,
          chapter,
        },
      };
    })
  );
}

const { book, sectionTitle, chapter } = Astro.props;
const videoId = getChapterVideoId(book, chapter);
const fullBookVideoId = getFullBookVideoId(book);
const chapterUrl = `https://thetablebible.org${getChapterUrl(book.slug, chapter)}`;
const chapterThumbUrl = getChapterThumbUrl(book.abbr, chapter);
const uploadDate = getVideoUploadDate(videoId);
const prevChapterUrl = chapter > 1 ? getChapterUrl(book.slug, chapter - 1) : null;
const nextChapterUrl = chapter < book.chapters ? getChapterUrl(book.slug, chapter + 1) : null;
const availableStarts = Array.from({ length: book.chapters }, (_, index) => index + 1).filter(startChapter => getPlayableChapterSequence(book, startChapter).length > 0);
const defaultStartChapter = availableStarts.includes(chapter) ? chapter : (availableStarts[availableStarts.length - 1] ?? 1);
const playAllUrl = getPlayAllUrl(book, defaultStartChapter);
const playAllCount = getPlayableChapterSequence(book, defaultStartChapter).length;
const nextFlowChapter = getPlayableChapterSequence(book, chapter)[1]?.chapter ?? null;
const nextFlowUrl = nextFlowChapter ? getPlayAllUrl(book, nextFlowChapter) : null;

const description = videoId
  ? `Read and listen to ${book.name} chapter ${chapter} from the World English Bible with word-by-word highlighted text on The Table Bible.`
  : `Explore ${book.name} chapter ${chapter} from the World English Bible on The Table Bible. Read it now in our Bible reader, or check back soon for the narrated version.`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${chapterUrl}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Library', item: 'https://thetablebible.org/library/' },
    { '@type': 'ListItem', position: 2, name: book.name, item: `https://thetablebible.org/library/${book.slug}/` },
    { '@type': 'ListItem', position: 3, name: `Chapter ${chapter}`, item: chapterUrl },
  ],
};

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${book.name} Chapter ${chapter} — The Table Bible`,
  url: chapterUrl,
  description,
  isPartOf: {
    '@type': 'CollectionPage',
    name: `${book.name} — The Table Bible`,
    url: `https://thetablebible.org/library/${book.slug}/`,
  },
  breadcrumb: {
    '@id': chapterUrl + '#breadcrumb',
  },
};

const videoLd = videoId
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: `${book.name} Chapter ${chapter} | World English Bible | The Table Bible`,
      description,
      embedUrl: `https://www.youtube-nocookie.com/embed/${videoId}`,
      contentUrl: `https://www.youtube.com/watch?v=${videoId}`,
      thumbnailUrl: [`https://thetablebible.org${chapterThumbUrl}`],
      ...(uploadDate ? { uploadDate } : {}),
      isFamilyFriendly: true,
      inLanguage: 'en',
      publisher: {
        '@type': 'Organization',
        name: 'The Table Bible',
        url: 'https://thetablebible.org',
      },
    }
  : null;
---

<BaseLayout
  title={`${book.name} Chapter ${chapter} — The Table Bible`}
  description={description}
  image={chapterThumbUrl}
  jsonLd={videoLd ? [breadcrumbLd, webPageLd, videoLd] : [breadcrumbLd, webPageLd]}
>
  <nav class="container-page pt-4 text-sm text-charcoal-muted" aria-label="Breadcrumb">
    <a href="/library/" class="text-accent hover:underline">Library</a>
    <span class="mx-1.5">›</span>
    <a href={`/library/${book.slug}/`} class="text-accent hover:underline">{book.name}</a>
    <span class="mx-1.5">›</span>
    <span>Chapter {chapter}</span>
  </nav>

  <section class="container-page py-8 text-center">
    <p class="text-gold-dark uppercase tracking-widest text-xs mb-2">{sectionTitle}</p>
    <h1 class="text-4xl mb-2">{book.name} Chapter {chapter}</h1>
    <p class="text-charcoal-muted mb-3">World English Bible · Chapter {chapter} of {book.chapters}</p>
    <p class="max-w-[760px] mx-auto text-base">{description}</p>
  </section>

  <section class="container-page pb-12">
    {videoId ? (
      <div class="card overflow-hidden">
        <div class="aspect-video w-full overflow-hidden rounded-t-xl bg-black">
          <iframe
            id="chapter-player-frame"
            src={`https://www.youtube-nocookie.com/embed/${videoId}?enablejsapi=1&rel=0&playsinline=1`}
            title={`${book.name} Chapter ${chapter} | The Table Bible`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
        <div class="flex gap-3 justify-center flex-wrap p-4">
          <a href={`https://www.youtube.com/watch?v=${videoId}`} target="_blank" rel="noopener" class="btn btn-secondary">Watch on YouTube</a>
          <a href={`/bible/${book.slug}/${chapter}/`} class="btn btn-primary">Read in Bible Reader</a>
        </div>
      </div>
    ) : (
      <div class="card overflow-hidden">
        <img
          src={chapterThumbUrl}
          alt={`${book.name} Chapter ${chapter}`}
          width="1280" height="720"
          loading="eager"
          class="w-full h-auto aspect-video object-cover block"
        />
        <div class="p-6 text-center">
          <h2 class="text-xl mb-2">Chapter Video Coming Soon</h2>
          <p class="max-w-[680px] mx-auto text-charcoal-muted mb-4">This page is already live so it can be indexed and linked. The matching video has not been synced to the website yet.</p>
          <div class="flex gap-3 justify-center flex-wrap">
            <a href={`/bible/${book.slug}/${chapter}/`} class="btn btn-primary">Read in Bible Reader</a>
            <a href={`/library/${book.slug}/`} class="btn btn-secondary">Back to {book.name}</a>
          </div>
        </div>
      </div>
    )}
  </section>

  <section class="container-page pb-12">
    <div class="grid grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-4">
      <article class="card p-6">
        <h2 class="text-xl mb-3">About This Chapter</h2>
        <p class="text-charcoal-muted">{book.name} chapter {chapter} is part of the World English Bible on The Table Bible. Read this chapter in the Bible reader with Strong's definitions and cross-references, or listen along with audio narration.</p>
      </article>
      {availableStarts.length > 0 && playAllUrl && (
        <article class="card p-6 bg-cream-200">
          <h2 class="text-xl mb-3">Play In Order</h2>
          <p class="text-charcoal-muted">Choose any available chapter, open that chapter page, and continue chapter by chapter to the end without another click.</p>
          <label for="chapter-play-all-start" class="sr-only">Choose starting chapter</label>
          <select id="chapter-play-all-start" class="w-full mt-4 px-4 py-3 rounded-lg border border-cream-300 bg-white font-sans text-sm">
            {availableStarts.map(startChapter => {
              const sequenceCount = getPlayableChapterSequence(book, startChapter).length;
              return (
                <option value={startChapter} selected={startChapter === defaultStartChapter}>
                  Start at chapter {startChapter} · {sequenceCount} {sequenceCount === 1 ? 'video' : 'videos'}
                </option>
              );
            })}
          </select>
          <a href={playAllUrl} class="btn btn-primary mt-4 inline-block" id="chapter-play-all-link">
            Play all from chapter {defaultStartChapter}{playAllCount > 0 ? ` (${playAllCount})` : ''}
          </a>
        </article>
      )}
      <article class="card p-6">
        <h2 class="text-xl mb-3">About {book.name}</h2>
        <p class="text-charcoal-muted">{book.description || `${book.name} is part of the Bible library on The Table Bible.`}</p>
      </article>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {prevChapterUrl ? <a href={prevChapterUrl} class="card flex items-center justify-center p-4 text-center no-underline hover:border-gold hover:-translate-y-0.5 transition-all">← {book.name} Chapter {chapter - 1}</a> : <div></div>}
      {fullBookVideoId ? <a href={`/watch/?v=${fullBookVideoId}`} class="card flex items-center justify-center p-4 text-center no-underline text-gold-dark hover:border-gold hover:-translate-y-0.5 transition-all">Full Book Video</a> : <a href={`/library/${book.slug}/`} class="card flex items-center justify-center p-4 text-center no-underline text-gold-dark hover:border-gold hover:-translate-y-0.5 transition-all">Book Overview</a>}
      {nextChapterUrl ? <a href={nextChapterUrl} class="card flex items-center justify-center p-4 text-center no-underline hover:border-gold hover:-translate-y-0.5 transition-all">{book.name} Chapter {chapter + 1} →</a> : <div></div>}
    </div>
  </section>
</BaseLayout>

<script define:vars={{
  playMap: Object.fromEntries(availableStarts.map(startChapter => [startChapter, { url: getPlayAllUrl(book, startChapter), count: getPlayableChapterSequence(book, startChapter).length }])),
  videoId,
  nextFlowUrl,
}}>
  const playAllSelect = document.getElementById('chapter-play-all-start');
  const playAllLink = document.getElementById('chapter-play-all-link');
  const playMapData = playMap;

  const syncPlayAllLink = () => {
    if (!(playAllSelect instanceof HTMLSelectElement) || !(playAllLink instanceof HTMLAnchorElement)) {
      return;
    }

    const selectedChapter = Number(playAllSelect.value);
    const selected = playMapData[selectedChapter];
    if (!selected?.url) {
      return;
    }

    playAllLink.href = selected.url;
    playAllLink.textContent = `Play all from chapter ${selectedChapter} (${selected.count})`;
  };

  syncPlayAllLink();
  playAllSelect?.addEventListener('change', () => {
    syncPlayAllLink();
    if (playAllLink instanceof HTMLAnchorElement && playAllLink.href) {
      window.location.href = playAllLink.href;
    }
  });

  const playerFrame = document.getElementById('chapter-player-frame');
  const pageParams = new URLSearchParams(window.location.search);
  const flowEnabled = pageParams.get('flow') === '1';
  const autoplayRequested = pageParams.get('autoplay') === '1';

  const startChapterFlow = () => {
    if (!(playerFrame instanceof HTMLIFrameElement) || !videoId || !window.YT?.Player) {
      return;
    }

    const embedParams = new URLSearchParams({
      enablejsapi: '1',
      rel: '0',
      playsinline: '1',
      origin: window.location.origin,
    });

    if (autoplayRequested) {
      embedParams.set('autoplay', '1');
    }

    playerFrame.src = `https://www.youtube-nocookie.com/embed/${videoId}?${embedParams.toString()}`;

    new window.YT.Player(playerFrame, {
      events: {
        onReady: event => {
          if (autoplayRequested) {
            event.target.playVideo();
          }
        },
        onStateChange: event => {
          if (flowEnabled && nextFlowUrl && event.data === window.YT.PlayerState.ENDED) {
            window.location.href = nextFlowUrl;
          }
        },
      },
    });
  };

  if (flowEnabled && playerFrame instanceof HTMLIFrameElement && videoId) {
    if (window.YT?.Player) {
      startChapterFlow();
    } else {
      const apiScript = document.createElement('script');
      apiScript.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(apiScript);

      const previousReady = window.onYouTubeIframeAPIReady;
      window.onYouTubeIframeAPIReady = () => {
        if (typeof previousReady === 'function') {
          previousReady();
        }
        startChapterFlow();
      };
    }
  }
</script>

