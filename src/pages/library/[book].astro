---
import BaseLayout from '../../layouts/BaseLayout.astro';
import libraryData from '../../data/library.json';
import { getChapterThumbUrl, getChapterUrl, getFullBookThumbUrl, getFullBookVideoId, getPlayAllUrl, getPlayableChapterSequence } from '../../utils/library';

export function getStaticPaths() {
  const books: any[] = [];
  for (const section of libraryData.sections) {
    for (const book of section.books) {
      books.push({
        params: { book: book.slug },
        props: { book, sectionTitle: section.title },
      });
    }
  }
  return books;
}

const { book, sectionTitle } = Astro.props;
const chapters = Array.from({ length: book.chapters }, (_, i) => i + 1);
const fullBookVideoId = getFullBookVideoId(book);
const availableStarts = chapters.filter(chapter => getPlayableChapterSequence(book, chapter).length > 0);
const defaultStartChapter = availableStarts[0] ?? 1;
const defaultPlayAllUrl = getPlayAllUrl(book, defaultStartChapter);
const defaultPlayAllCount = getPlayableChapterSequence(book, defaultStartChapter).length;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `https://thetablebible.org/library/${book.slug}/#breadcrumb`,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Library", "item": "https://thetablebible.org/library/" },
    { "@type": "ListItem", "position": 2, "name": book.name, "item": `https://thetablebible.org/library/${book.slug}/` },
  ],
};

const bookLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": book.name,
  "url": `https://thetablebible.org/library/${book.slug}/`,
  "description": book.description || `Read the Book of ${book.name} on The Table Bible.`,
  "bookFormat": "EBook",
  "inLanguage": "en",
};
---

<BaseLayout
  title={`${book.name} — The Table Bible`}
  description={book.description || `Listen to the Book of ${book.name} — all ${book.chapters} chapters with word-by-word highlighted text. World English Bible (WEB).`}
  image={getFullBookThumbUrl(book.abbr)}
  jsonLd={[breadcrumbLd, bookLd]}
>
  <!-- Breadcrumb -->
  <nav class="container-page pt-4 text-sm text-charcoal-muted" aria-label="Breadcrumb">
    <a href="/library/" class="text-accent hover:underline">Library</a>
    <span class="mx-1.5">›</span>
    <span>{book.name}</span>
  </nav>

  <!-- Book Header -->
  <section class="py-8 text-center">
    <div class="container-page">
      <h1 class="text-4xl mb-2">{book.name}</h1>
      <p class="text-gold-dark">{sectionTitle} · {book.chapters} {book.chapters === 1 ? 'chapter' : 'chapters'}</p>
      {book.description && (
        <p class="book-description max-w-[640px] mx-auto mt-4 font-serif text-base leading-relaxed text-left">{book.description}</p>
      )}

      {availableStarts.length > 0 && (
        <div class="mt-8 mx-auto max-w-[920px] grid md:grid-cols-[1.6fr_minmax(260px,1fr)] gap-6 items-center p-6 border border-cream-300 rounded-2xl bg-cream-200 shadow-card">
          <div class="text-left">
            <span class="inline-block mb-2 text-gold-dark text-xs tracking-widest uppercase">Play In Order</span>
            <h2 class="text-2xl mb-2">Start this book anywhere and keep going</h2>
            <p class="text-charcoal-muted">
              Choose a chapter, open that chapter page, and continue through the remaining available chapters automatically.
            </p>
          </div>
          <div class="grid gap-3">
            <label for="play-all-start" class="sr-only">Choose starting chapter</label>
            <select id="play-all-start" class="play-all-select w-full px-4 py-3 rounded-lg border border-cream-300 bg-white font-sans text-sm" data-base-book={book.name}>
              {availableStarts.map(chapter => {
                const sequenceCount = getPlayableChapterSequence(book, chapter).length;
                return (
                  <option value={chapter} selected={chapter === defaultStartChapter}>
                    Start at chapter {chapter} · {sequenceCount} {sequenceCount === 1 ? 'video' : 'videos'}
                  </option>
                );
              })}
            </select>
            {defaultPlayAllUrl && (
              <a
                href={defaultPlayAllUrl}
                class="btn btn-primary w-full text-center"
                id="play-all-link"
                data-book-slug={book.slug}
              >
                Play all from chapter {defaultStartChapter}{defaultPlayAllCount > 0 ? ` (${defaultPlayAllCount})` : ''}
              </a>
            )}
            <p class="text-charcoal-muted text-sm">Choose any available chapter and its chapter page starts the onward flow right away.</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Top Row: Full Book Video + MP3 -->
  <section class="container-page pb-12">
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <h2 class="font-serif text-lg mb-3">Full Book Video</h2>
        {fullBookVideoId ? (
          <a href={`/watch/?v=${fullBookVideoId}`} class="card block overflow-hidden no-underline hover:-translate-y-0.5 transition-transform">
            <div class="relative aspect-video bg-cream-200">
              <img src={getFullBookThumbUrl(book.abbr)} alt={`${book.name} — Full Book`} width="640" height="360" loading="eager" class="block w-full h-full object-cover" />
              <div class="absolute inset-0 flex items-center justify-center text-5xl text-white bg-black/35 opacity-0 hover:opacity-100 transition-opacity">▶</div>
            </div>
            <span class="block p-3 text-sm text-center">Watch All {book.chapters} Chapters</span>
          </a>
        ) : (
          <div class="card overflow-hidden opacity-70">
            <div class="relative aspect-video bg-cream-200">
              <img src={getFullBookThumbUrl(book.abbr)} alt={`${book.name} — Full Book`} width="640" height="360" loading="eager" class="block w-full h-full object-cover" />
              <div class="absolute inset-0 flex items-center justify-center text-xl font-medium bg-black/55 text-white tracking-wide">Coming Soon</div>
            </div>
            <span class="block p-3 text-sm text-center">Full Book — Coming Soon</span>
          </div>
        )}
      </div>

      <div>
        <h2 class="font-serif text-lg mb-3">MP3 Audio</h2>
        <div class="card overflow-hidden opacity-70">
          <div class="aspect-video bg-cream-200 flex items-center justify-center text-gold">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.6">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
          </div>
          <span class="block p-3 text-sm text-center">MP3 Download — Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapter Thumbnails Grid -->
  <section class="container-page pb-12">
    <h2 class="font-serif text-xl text-gold-dark mb-6 pb-2 border-b border-cream-300">Chapters</h2>
    <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-4">
      {chapters.map(ch => {
        const videoId = book.videos?.[String(ch)] || null;
        const playFromChapterUrl = videoId ? getPlayAllUrl(book, ch) : null;
        return (
          <a
            href={playFromChapterUrl || getChapterUrl(book.slug, ch)}
            class:list={['chapter-card flex flex-col items-center text-center gap-1.5 no-underline transition-transform', { 'cursor-pointer hover:-translate-y-1': !!videoId, 'pointer-events-none opacity-60': !videoId }]}
            aria-label={videoId ? `${book.name} Chapter ${ch}, play from this chapter onward` : `${book.name} Chapter ${ch}`}
          >
            <div class="relative w-full rounded-lg overflow-hidden border border-cream-300 hover:border-gold transition-colors">
              {videoId && <div class="absolute inset-0 flex items-center justify-center text-3xl text-white bg-black/30 opacity-0 hover:opacity-100 transition-opacity z-10">▶</div>}
              <img
                src={getChapterThumbUrl(book.abbr, ch)}
                alt={`${book.name} Chapter ${ch}`}
                width="640" height="360"
                loading="lazy"
                decoding="async"
                class="block w-full h-auto aspect-video object-cover bg-cream-200"
              />
            </div>
            <span class="font-sans text-sm font-medium">Chapter {ch}</span>
            {videoId && <span class="text-xs text-gold-dark uppercase tracking-wide">Play from here</span>}
          </a>
        );
      })}
    </div>
  </section>

  <!-- Back to Library -->
  <section class="container-page pb-16 text-center">
    <a href="/library/" class="btn btn-secondary">← Back to Library</a>
  </section>
</BaseLayout>

<script define:vars={{ availableStarts, bookName: book.name, bookSlug: book.slug, playMap: Object.fromEntries(availableStarts.map(chapter => [chapter, { url: getPlayAllUrl(book, chapter), count: getPlayableChapterSequence(book, chapter).length }])) }}>
  const playAllSelect = document.getElementById('play-all-start');
  const playAllLink = document.getElementById('play-all-link');
  const playMapData = playMap;

  const syncPlayAllLink = () => {
    if (!(playAllSelect instanceof HTMLSelectElement) || !(playAllLink instanceof HTMLAnchorElement)) {
      return;
    }

    const selectedChapter = Number(playAllSelect.value);
    const selected = playMapData[selectedChapter];
    if (!selected?.url) {
      return;
    }

    playAllLink.href = selected.url;
    playAllLink.textContent = `Play all from chapter ${selectedChapter} (${selected.count})`;
  };

  syncPlayAllLink();
  playAllSelect?.addEventListener('change', () => {
    syncPlayAllLink();
    if (playAllLink instanceof HTMLAnchorElement && playAllLink.href) {
      window.location.href = playAllLink.href;
    }
  });
</script>

