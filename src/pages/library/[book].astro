---
import BaseLayout from '../../layouts/BaseLayout.astro';
import libraryData from '../../data/library.json';
import { getChapterThumbUrl, getChapterUrl, getFullBookThumbUrl, getFullBookVideoId, getPlayAllUrl, getPlayableChapterSequence } from '../../utils/library';

export function getStaticPaths() {
  const books: any[] = [];
  for (const section of libraryData.sections) {
    for (const book of section.books) {
      books.push({
        params: { book: book.slug },
        props: { book, sectionTitle: section.title },
      });
    }
  }
  return books;
}

const { book, sectionTitle } = Astro.props;
const chapters = Array.from({ length: book.chapters }, (_, i) => i + 1);
const fullBookVideoId = getFullBookVideoId(book);
const availableStarts = chapters.filter(chapter => getPlayableChapterSequence(book, chapter).length > 0);
const defaultStartChapter = availableStarts[0] ?? 1;
const defaultPlayAllUrl = getPlayAllUrl(book, defaultStartChapter);
const defaultPlayAllCount = getPlayableChapterSequence(book, defaultStartChapter).length;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `https://thetablebible.org/library/${book.slug}/#breadcrumb`,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Library", "item": "https://thetablebible.org/library/" },
    { "@type": "ListItem", "position": 2, "name": book.name, "item": `https://thetablebible.org/library/${book.slug}/` },
  ],
};

const bookLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": book.name,
  "url": `https://thetablebible.org/library/${book.slug}/`,
  "description": book.description || `Read the Book of ${book.name} on The Table Bible.`,
  "bookFormat": "EBook",
  "inLanguage": "en",
};
---

<BaseLayout
  title={`${book.name} — The Table Bible`}
  description={book.description || `Listen to the Book of ${book.name} — all ${book.chapters} chapters with word-by-word highlighted text. World English Bible (WEB).`}
  image={getFullBookThumbUrl(book.abbr)}
  jsonLd={[breadcrumbLd, bookLd]}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/library/">Library</a>
    <span class="separator">›</span>
    <span class="current">{book.name}</span>
  </nav>

  <!-- Book Header -->
  <section class="book-hero">
    <div class="container">
      <h1>{book.name}</h1>
      <p class="book-meta">{sectionTitle} · {book.chapters} {book.chapters === 1 ? 'chapter' : 'chapters'}</p>
      {book.description && (
        <p class="book-description">{book.description}</p>
      )}

      {availableStarts.length > 0 && (
        <div class="play-all-panel">
          <div class="play-all-copy">
            <span class="play-all-kicker">Play In Order</span>
            <h2>Start this book anywhere and keep going</h2>
            <p>
              Choose a chapter, open that chapter page, and continue through the remaining available chapters automatically.
            </p>
          </div>
          <div class="play-all-controls">
            <label for="play-all-start" class="sr-only">Choose starting chapter</label>
            <select id="play-all-start" class="play-all-select" data-base-book={book.name}>
              {availableStarts.map(chapter => {
                const sequenceCount = getPlayableChapterSequence(book, chapter).length;
                return (
                  <option value={chapter} selected={chapter === defaultStartChapter}>
                    Start at chapter {chapter} · {sequenceCount} {sequenceCount === 1 ? 'video' : 'videos'}
                  </option>
                );
              })}
            </select>
            {defaultPlayAllUrl && (
              <a
                href={defaultPlayAllUrl}
                class="btn btn-primary btn-lg play-all-button"
                id="play-all-link"
                data-book-slug={book.slug}
              >
                Play all from chapter {defaultStartChapter}{defaultPlayAllCount > 0 ? ` (${defaultPlayAllCount})` : ''}
              </a>
            )}
            <p class="play-all-helper">Choose any available chapter and its chapter page starts the onward flow right away.</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Top Row: Full Book Video + MP3 -->
  <section class="top-row container">
    <div class="top-row-grid">
      <div class="top-row-item">
        <h2>📖 Full Book Video</h2>
        {fullBookVideoId ? (
          <a href={`/watch/?v=${fullBookVideoId}`} class="top-row-card">
            <div class="top-row-thumb">
              <img
                src={getFullBookThumbUrl(book.abbr)}
                alt={`${book.name} — Full Book`}
                width="640" height="360"
                loading="eager"
              />
              <div class="play-overlay">▶</div>
            </div>
            <span class="top-row-label">Watch All {book.chapters} Chapters</span>
          </a>
        ) : (
          <div class="top-row-card coming-soon">
            <div class="top-row-thumb">
              <img
                src={getFullBookThumbUrl(book.abbr)}
                alt={`${book.name} — Full Book`}
                width="640" height="360"
                loading="eager"
              />
              <div class="coming-overlay">Coming Soon</div>
            </div>
            <span class="top-row-label">Full Book — Coming Soon</span>
          </div>
        )}
      </div>

      <div class="top-row-item">
        <h2>🎧 MP3 Audio</h2>
        <div class="top-row-card coming-soon">
          <div class="top-row-thumb mp3-thumb">
            <div class="mp3-icon">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.6">
                <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
              </svg>
            </div>
          </div>
          <span class="top-row-label">MP3 Download — Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapter Thumbnails Grid -->
  <section class="chapters-section container">
    <h2>Chapters</h2>
    <div class="chapter-grid">
      {chapters.map(ch => {
        const videoId = book.videos?.[String(ch)] || null;
        const playFromChapterUrl = videoId ? getPlayAllUrl(book, ch) : null;
        return (
          <a
            href={playFromChapterUrl || getChapterUrl(book.slug, ch)}
            class:list={['chapter-card', { 'has-video': !!videoId, 'no-video': !videoId }]}
            aria-label={videoId ? `${book.name} Chapter ${ch}, play from this chapter onward` : `${book.name} Chapter ${ch}`}
          >
            <div class="card-thumb">
              {videoId && <div class="play-icon" aria-hidden="true">▶</div>}
              <img
                src={getChapterThumbUrl(book.abbr, ch)}
                alt={`${book.name} Chapter ${ch}`}
                width="640" height="360"
                loading="lazy"
                decoding="async"
              />
            </div>
            <span class="card-label">Chapter {ch}</span>
            {videoId && <span class="card-status">Play from here</span>}
          </a>
        );
      })}
    </div>
  </section>

  <!-- Back to Library -->
  <section class="back-section container">
    <a href="/library/" class="btn btn-secondary">← Back to Library</a>
  </section>
</BaseLayout>

<script define:vars={{ availableStarts, bookName: book.name, bookSlug: book.slug, playMap: Object.fromEntries(availableStarts.map(chapter => [chapter, { url: getPlayAllUrl(book, chapter), count: getPlayableChapterSequence(book, chapter).length }])) }}>
  const playAllSelect = document.getElementById('play-all-start');
  const playAllLink = document.getElementById('play-all-link');
  const playMapData = playMap;

  const syncPlayAllLink = () => {
    if (!(playAllSelect instanceof HTMLSelectElement) || !(playAllLink instanceof HTMLAnchorElement)) {
      return;
    }

    const selectedChapter = Number(playAllSelect.value);
    const selected = playMapData[selectedChapter];
    if (!selected?.url) {
      return;
    }

    playAllLink.href = selected.url;
    playAllLink.textContent = `Play all from chapter ${selectedChapter} (${selected.count})`;
  };

  syncPlayAllLink();
  playAllSelect?.addEventListener('change', () => {
    syncPlayAllLink();
    if (playAllLink instanceof HTMLAnchorElement && playAllLink.href) {
      window.location.href = playAllLink.href;
    }
  });
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .breadcrumb {
    padding: var(--space-lg) var(--space-lg) 0;
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  .breadcrumb a { color: var(--gold-light); }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .separator { margin: 0 var(--space-sm); color: var(--text-muted); }
  .breadcrumb .current { color: var(--cream); }

  .book-hero {
    padding: var(--space-2xl) 0;
    text-align: center;
  }
  .book-hero h1 { margin-bottom: var(--space-sm); }
  .book-meta { color: var(--gold-light); font-size: 1rem; }
  .book-description {
    max-width: 640px;
    margin: var(--space-lg) auto 0;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--cream);
    text-align: left;
  }
  .book-description::first-letter {
    float: left;
    font-family: 'UnifrakturMaguntia', cursive;
    font-size: 3.4em;
    line-height: 0.8;
    padding: 0.05em 0.12em 0 0;
    margin-top: 0.05em;
    color: #6B0F1A;
    background: #C9A227;
    border-radius: 3px;
  }

  .play-all-panel {
    margin: var(--space-2xl) auto 0;
    max-width: 920px;
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(260px, 1fr);
    gap: var(--space-xl);
    align-items: center;
    padding: var(--space-xl);
    border: 1px solid rgba(201, 168, 106, 0.18);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at top left, rgba(201, 168, 106, 0.12), transparent 45%),
      linear-gradient(180deg, rgba(42, 35, 30, 0.98), rgba(30, 24, 20, 0.98));
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.22);
  }

  .play-all-kicker {
    display: inline-block;
    margin-bottom: var(--space-sm);
    color: var(--gold-light);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .play-all-copy h2 {
    margin-bottom: var(--space-sm);
    font-size: clamp(1.35rem, 2.2vw, 1.8rem);
  }

  .play-all-copy p {
    margin: 0;
    color: var(--text-muted);
  }

  .play-all-controls {
    display: grid;
    gap: var(--space-md);
  }

  .play-all-helper {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .play-all-select {
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid rgba(201, 168, 106, 0.25);
    background: rgba(20, 17, 14, 0.82);
    color: var(--cream);
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  .play-all-button {
    width: 100%;
    justify-content: center;
  }

  /* ── Top Row ─────────────────────────────────────────────────────── */
  .top-row { padding-bottom: var(--space-3xl); }
  .top-row-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }
  .top-row-item h2 {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--cream);
    margin-bottom: var(--space-md);
  }
  .top-row-card {
    display: block;
    border: 1px solid rgba(201, 168, 106, 0.15);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), transform var(--transition-base);
  }
  .top-row-card:hover:not(.coming-soon) {
    border-color: var(--gold-light);
    transform: translateY(-2px);
  }
  .top-row-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-secondary);
  }
  .top-row-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: white;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  .top-row-card:hover .play-overlay { opacity: 1; }
  .coming-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--cream);
    background: rgba(0, 0, 0, 0.55);
    letter-spacing: 0.05em;
  }
  .top-row-label {
    display: block;
    padding: var(--space-md);
    font-size: 0.9375rem;
    color: var(--cream);
    text-align: center;
  }

  .mp3-thumb {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-light);
  }

  /* ── Chapter Grid ────────────────────────────────────────────────── */
  .chapters-section {
    padding-bottom: var(--space-3xl);
  }
  .chapters-section h2 {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--gold-light);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(201, 168, 106, 0.15);
  }
  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-lg);
  }
  .chapter-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base);
  }
  .chapter-card.has-video { cursor: pointer; }
  .chapter-card.has-video:hover { transform: translateY(-3px); }
  .chapter-card.no-video { pointer-events: none; }

  .card-thumb {
    position: relative;
    width: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(201, 168, 106, 0.15);
    transition: border-color var(--transition-fast);
  }
  .chapter-card.has-video:hover .card-thumb { border-color: var(--gold-light); }
  .card-thumb img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--bg-secondary);
  }
  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: white;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: 2;
    pointer-events: none;
  }
  .chapter-card.has-video:hover .play-icon { opacity: 1; }
  .card-label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--cream);
  }

  .card-status {
    font-size: 0.75rem;
    color: var(--gold-light);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .back-section {
    padding-bottom: var(--space-4xl);
    text-align: center;
  }

  @media (max-width: 768px) {
    .play-all-panel {
      grid-template-columns: 1fr;
      text-align: left;
    }

    .top-row-grid { grid-template-columns: 1fr; }
    .chapter-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
  }
</style>
