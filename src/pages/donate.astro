---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Support — The Table Bible" description="Support The Table Bible ministry. All videos are free — your generosity helps us continue making Scripture accessible to all.">
  <section class="donate-hero">
    <div class="container container-narrow">
      <h1>Support This Ministry</h1>
      <div class="divider"></div>
      <p class="donate-intro">
        The Table Bible is and always will be free to watch, download, and share. 
        We believe Scripture should be accessible to everyone, with no barriers.
      </p>
    </div>
  </section>
  
  <section class="donate-content">
    <div class="container container-narrow">
      <div class="donate-message">
        <h2>Why We Need Your Help</h2>
        <p>
          Creating high-quality Bible narration videos requires significant time and resources. 
          From audio production to 4K video rendering, every chapter represents hours of careful work.
        </p>
        <p>
          Your generous gift helps cover:
        </p>
        <ul class="impact-list">
          <li>
            <span class="impact-icon">🎙️</span>
            <span>Audio production and narration</span>
          </li>
          <li>
            <span class="impact-icon">🎬</span>
            <span>Video rendering and hosting</span>
          </li>
          <li>
            <span class="impact-icon">🌐</span>
            <span>Website and infrastructure costs</span>
          </li>
          <li>
            <span class="impact-icon">📚</span>
            <span>Expansion to new translations and languages</span>
          </li>
        </ul>
      </div>
      
      <div class="donate-options">
        <h2>Ways to Give</h2>
        
        <div class="donate-cards">
          <div class="donate-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect width="20" height="14" x="2" y="5" rx="2"/>
                <line x1="2" x2="22" y1="10" y2="10"/>
              </svg>
            </div>
            <h3>Credit / Debit Card</h3>
            <p>Secure payment via Stripe. Choose any amount — no account required.</p>
            <a href="https://donate.stripe.com/dRmcN71tY1bg8Lj19NaZi00" target="_blank" rel="noopener" class="btn btn-primary donate-btn">
              Give with Card
            </a>
          </div>
          
          <div class="donate-card">
            <div class="card-icon paypal">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944 3.72a.77.77 0 0 1 .757-.64h6.394c2.149 0 3.792.463 4.885 1.377.55.46.96 1.01 1.22 1.63.266.635.38 1.37.342 2.184-.015.286-.042.576-.092.876-.416 2.548-1.845 4.315-4.137 5.107a9.1 9.1 0 0 1-3.171.507H9.344a.945.945 0 0 0-.933.79l-.001.006-.836 5.284-.02.132a.64.64 0 0 1-.633.54l.155-.076z"/>
              </svg>
            </div>
            <h3>PayPal</h3>
            <p>Give through PayPal — use your balance or any linked payment method.</p>
            <a href="https://www.paypal.com/ncp/payment/829Y8JMJBUC2J" target="_blank" rel="noopener" class="btn btn-primary donate-btn paypal-btn">
              Give with PayPal
            </a>
          </div>
          
          <div class="donate-card">
            <div class="card-icon youtube">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
              </svg>
            </div>
            <h3>YouTube "Thanks"</h3>
            <p>Use YouTube's built-in "Thanks" button on any video to show appreciation.</p>
            <a href="https://youtube.com/@thetablebibleorg" target="_blank" rel="noopener" class="btn btn-secondary">
              Visit Channel
            </a>
          </div>
        </div>
      </div>
      
      <div class="donate-transparency">
        <h2>Our Promise</h2>
        <div class="promise-grid">
          <div class="promise-item">
            <div class="promise-icon">✓</div>
            <div>
              <h4>100% Free Content</h4>
              <p>Every video remains free forever. No paywalls, no premium tiers.</p>
            </div>
          </div>
          <div class="promise-item">
            <div class="promise-icon">✓</div>
            <div>
              <h4>Public Domain</h4>
              <p>All content can be freely shared, downloaded, and used for any purpose.</p>
            </div>
          </div>
          <div class="promise-item">
            <div class="promise-icon">✓</div>
            <div>
              <h4>Ministry First</h4>
              <p>We exist to serve, not to profit. Your gift goes directly to the mission.</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="donate-note">
        <p>
          <strong>Note:</strong> Come to the Table Ministries is not currently a registered 501(c)(3). 
          Donations are not tax-deductible at this time. We are grateful for your generosity regardless.
        </p>
      </div>
    </div>
  </section>
  
  <section class="donate-gratitude">
    <div class="container container-narrow">
      <blockquote>
        "If this ministry blesses you, consider blessing it in return. 
        But if you cannot give, please know that you are still welcome at the Table."
      </blockquote>
      <p class="signature">— The Table Bible Team</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Donate Hero ─────────────────────────────────────────────────── */
  .donate-hero {
    padding: var(--space-4xl) 0;
    text-align: center;
    background: var(--bg-secondary);
  }
  
  .donate-hero h1 {
    margin-bottom: var(--space-lg);
  }
  
  .donate-intro {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* ── Donate Content ──────────────────────────────────────────────── */
  .donate-content {
    padding: var(--space-4xl) 0;
  }
  
  .donate-message {
    margin-bottom: var(--space-4xl);
  }
  
  .donate-message h2 {
    margin-bottom: var(--space-lg);
  }
  
  .donate-message p {
    color: var(--text-muted);
    font-size: 1.125rem;
  }
  
  .impact-list {
    list-style: none;
    margin-top: var(--space-xl);
    display: grid;
    gap: var(--space-md);
  }
  
  .impact-list li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--bg-card);
    border-radius: var(--radius-md);
    border: 1px solid rgba(201, 168, 106, 0.1);
  }
  
  .impact-icon {
    font-size: 1.5rem;
  }
  
  /* ── Donate Options ──────────────────────────────────────────────── */
  .donate-options {
    margin-bottom: var(--space-4xl);
  }
  
  .donate-options h2 {
    margin-bottom: var(--space-xl);
    text-align: center;
  }
  
  .donate-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }
  
  .donate-card {
    position: relative;
    padding: var(--space-xl);
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(201, 168, 106, 0.1);
    text-align: center;
    transition: all var(--transition-base);
  }
  
  .donate-card:hover {
    border-color: rgba(201, 168, 106, 0.25);
  }
  
  .donate-card.featured {
    border-color: var(--gold-light);
    background: linear-gradient(180deg, rgba(201, 162, 39, 0.1) 0%, var(--bg-card) 100%);
  }
  
  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: var(--space-xs) var(--space-md);
    background: var(--gold);
    color: var(--espresso);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-xl);
  }
  
  .donate-card h3 {
    margin-bottom: var(--space-md);
    color: var(--gold-light);
  }
  
  .donate-card p {
    color: var(--text-muted);
    font-size: 0.9375rem;
    margin-bottom: var(--space-lg);
  }
  
  .donate-btn {
    width: 100%;
  }
  
  .card-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
    border-radius: 50%;
    color: var(--espresso);
  }
  
  .card-icon.paypal {
    background: linear-gradient(135deg, #0070ba 0%, #003087 100%);
    color: white;
  }
  
  .card-icon.youtube {
    background: linear-gradient(135deg, #ff0000 0%, #cc0000 100%);
    color: white;
  }
  
  .paypal-btn {
    background: linear-gradient(135deg, #0070ba 0%, #003087 100%);
    border-color: #0070ba;
  }
  
  .paypal-btn:hover {
    background: linear-gradient(135deg, #003087 0%, #001f5c 100%);
    border-color: #003087;
  }

  /* ── Transparency Section ────────────────────────────────────────── */
  .donate-transparency {
    padding: var(--space-3xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-3xl);
  }
  
  .donate-transparency h2 {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  
  .promise-grid {
    display: grid;
    gap: var(--space-lg);
  }
  
  .promise-item {
    display: flex;
    gap: var(--space-md);
  }
  
  .promise-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201, 162, 39, 0.2);
    color: var(--gold);
    border-radius: 50%;
    font-weight: bold;
  }
  
  .promise-item h4 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
    color: var(--cream);
  }
  
  .promise-item p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0;
  }
  
  /* ── Note ────────────────────────────────────────────────────────── */
  .donate-note {
    padding: var(--space-lg);
    background: rgba(107, 15, 26, 0.2);
    border: 1px solid rgba(107, 15, 26, 0.3);
    border-radius: var(--radius-md);
  }
  
  .donate-note p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
    text-align: center;
  }
  
  /* ── Gratitude Section ───────────────────────────────────────────── */
  .donate-gratitude {
    padding: var(--space-4xl) 0;
    background: var(--bg-secondary);
    text-align: center;
  }
  
  .donate-gratitude blockquote {
    font-size: 1.375rem;
    font-style: italic;
    color: var(--cream);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto var(--space-lg);
  }
  
  .signature {
    color: var(--gold-light);
    font-size: 1rem;
  }
  
  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .donate-cards {
      grid-template-columns: 1fr;
    }
    
    .donate-card.featured {
      order: -1;
    }
  }
</style>
