---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pay It Forward — The Table Bible" description="The Table Bible is free because real people made it possible. Your gift keeps it free for the next person who needs it.">
  <main class="container-narrow py-12">
    <header class="text-center mb-12">
      <h1 class="text-4xl mb-4">Pay It Forward</h1>
      <div class="divider"></div>
      <p class="text-lg text-charcoal-muted max-w-[600px] mx-auto leading-relaxed mt-4">
        This content remains free because of generous givers like you. No ads. No paywalls. 
        No subscriptions. Just open Scripture for anyone who needs it. When you give, 
        you're not paying for what you've read — you're making it possible for the 
        next person to read it too.
      </p>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl mb-4">Where Your Gift Goes</h2>
      <p class="text-lg text-charcoal-muted leading-relaxed mb-6">
        Every gift goes directly to keeping this resource free and growing. 
        Here's what your generosity makes possible for the next reader:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="card p-4 flex items-center gap-3">
          <span class="text-2xl">📖</span>
          <span>Bible reader and study tools</span>
        </div>
        <div class="card p-4 flex items-center gap-3">
          <span class="text-2xl">🎙️</span>
          <span>Audio narration and production</span>
        </div>
        <div class="card p-4 flex items-center gap-3">
          <span class="text-2xl">✏️</span>
          <span>Daily devotionals and meditations</span>
        </div>
        <div class="card p-4 flex items-center gap-3">
          <span class="text-2xl">🌐</span>
          <span>Website hosting and infrastructure</span>
        </div>
      </div>
    </section>

    <section id="ways-to-give" class="mb-12 scroll-mt-24">
      <h2 class="text-2xl text-center mb-6">Ways to Give</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <div class="card p-6 text-center">
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center bg-gold-50 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold-dark">
              <rect width="20" height="14" x="2" y="5" rx="2"/>
              <line x1="2" x2="22" y1="10" y2="10"/>
            </svg>
          </div>
          <h3 class="text-lg mb-2">Credit / Debit Card</h3>
          <p class="text-sm text-charcoal-muted mb-4">Secure payment via Stripe. Choose any amount — no account required.</p>
          <a href="https://donate.stripe.com/dRmcN71tY1bg8Lj19NaZi00" target="_blank" rel="noopener" class="btn-primary w-full block text-center">
            Give with Card
          </a>
        </div>

        <div class="card p-6 text-center">
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center bg-blue-50 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-blue-600">
              <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944 3.72a.77.77 0 0 1 .757-.64h6.394c2.149 0 3.792.463 4.885 1.377.55.46.96 1.01 1.22 1.63.266.635.38 1.37.342 2.184-.015.286-.042.576-.092.876-.416 2.548-1.845 4.315-4.137 5.107a9.1 9.1 0 0 1-3.171.507H9.344a.945.945 0 0 0-.933.79l-.001.006-.836 5.284-.02.132a.64.64 0 0 1-.633.54l.155-.076z"/>
            </svg>
          </div>
          <h3 class="text-lg mb-2">PayPal</h3>
          <p class="text-sm text-charcoal-muted mb-4">Give through PayPal — use your balance or any linked payment method.</p>
          <a href="https://www.paypal.com/ncp/payment/829Y8JMJBUC2J" target="_blank" rel="noopener" class="btn-primary w-full block text-center">
            Give with PayPal
          </a>
        </div>
      </div>
    </section>

    <section class="bg-cream-200 rounded-lg p-8 mb-12">
      <h2 class="text-2xl text-center mb-6">Our Promise to You</h2>
      <div class="grid gap-4">
        <div class="flex gap-3 items-start">
          <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gold-50 text-gold-dark rounded-full font-bold">✓</span>
          <div>
            <h4 class="font-sans font-medium mb-1">100% Free Content</h4>
            <p class="text-sm text-charcoal-muted">Every resource remains free forever. No paywalls, no premium tiers.</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gold-50 text-gold-dark rounded-full font-bold">✓</span>
          <div>
            <h4 class="font-sans font-medium mb-1">Always Accessible</h4>
            <p class="text-sm text-charcoal-muted">Every resource stays free to read, listen to, and share right here.</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gold-50 text-gold-dark rounded-full font-bold">✓</span>
          <div>
            <h4 class="font-sans font-medium mb-1">Ministry First</h4>
            <p class="text-sm text-charcoal-muted">We exist to serve, not to profit. Your gift goes directly to the mission.</p>
          </div>
        </div>
      </div>
    </section>

    <div class="bg-gold-50 border border-gold-light rounded p-4 text-sm text-charcoal-muted mb-12">
      <strong>Note:</strong> The Table Bible Ministries is not currently a registered 501(c)(3). 
      Donations are not tax-deductible at this time. We are grateful for your generosity regardless.
    </div>

    <blockquote class="scripture-block text-center">
      <p class="text-lg mb-3">
        "If this blessed you, pay it forward. And if you can't give today, 
        you are still welcome at the Table. Always."
      </p>
      <footer class="text-sm text-charcoal-muted not-italic">— The Table Bible Team</footer>
    </blockquote>
  </main>
</BaseLayout>
