---
import BaseLayout from '../layouts/BaseLayout.astro';
import libraryData from '../data/library.json';

const { sections } = libraryData;
const otSections = sections.filter(s => ['pentateuch', 'history', 'wisdom', 'prophets'].includes(s.id));
const ntSections = sections.filter(s => ['gospels', 'acts-letters'].includes(s.id));
const allBooks = [...otSections.flatMap(s => s.books), ...ntSections.flatMap(s => s.books)];
---

<BaseLayout title="The Table Bible — Read, Listen, and Study the Bible Online for Free">
  <!-- Hero -->
  <section class="py-14 md:py-20">
    <div class="container-page max-w-[780px] text-center mx-auto">
      <img src="/images/profile_800x800.png" alt="The Table Bible" class="hero-logo mx-auto mb-5" width="120" height="120" />
      <h1 class="text-4xl md:text-5xl leading-tight mb-4">The Complete Bible — Read, Study, Understand</h1>
      <p class="text-lg text-charcoal-light leading-relaxed mb-8 max-w-[640px] mx-auto">
        Strong's definitions on every word. Audio narration for every chapter. Daily devotionals, theologian insights, and a 730-day Psalm meditation. Always free.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 items-center justify-center mb-4">
        <select id="book-picker" class="px-4 py-2.5 bg-white border border-cream-300 rounded-lg font-sans text-base outline-none focus:border-gold w-full sm:w-auto">
          <optgroup label="Old Testament">
            {otSections.flatMap(s => s.books).map(b => (
              <option value={b.slug}>{b.name}</option>
            ))}
          </optgroup>
          <optgroup label="New Testament">
            {ntSections.flatMap(s => s.books).map(b => (
              <option value={b.slug}>{b.name}</option>
            ))}
          </optgroup>
        </select>
        <a id="start-reading-btn" href="/bible/genesis/1/" class="btn btn-primary text-base whitespace-nowrap">
          Start Reading
        </a>
      </div>
      <p class="text-sm text-charcoal-muted">Tap any word for its original Greek or Hebrew definition.</p>
      <a id="continue-reading" href="#" class="hidden items-center gap-2 mt-3 text-sm text-gold font-medium hover:underline no-underline justify-center">
        <span>📑</span>
        <span id="continue-reading-label">Continue reading</span>
      </a>
    </div>
  </section>

  <!-- Main Resource Cards -->
  <section class="bg-cream-200 py-12">
    <div class="container-page">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/bible/genesis/1/" class="card p-6 no-underline hover:-translate-y-1 transition-transform group">
          <div class="text-3xl mb-3">📖</div>
          <h3 class="text-lg mb-1 group-hover:text-accent transition-colors">Bible Reader</h3>
          <p class="text-sm text-charcoal-light mb-3">Read every chapter with Strong's Greek and Hebrew definitions. Tap any word to see its original meaning.</p>
          <span class="text-xs font-sans text-charcoal-muted">66 books</span>
        </a>
        <a href="/devotional/archive/" class="card p-6 no-underline hover:-translate-y-1 transition-transform group">
          <div class="text-3xl mb-3">✏️</div>
          <h3 class="text-lg mb-1 group-hover:text-accent transition-colors">Daily Devotional</h3>
          <p class="text-sm text-charcoal-light mb-3">Teaching, theologian quotes, and reflection questions for every chapter of the Bible.</p>
          <span class="text-xs font-sans text-charcoal-muted">1,189 chapters</span>
        </a>
        <a href="/meditation/" class="card p-6 no-underline hover:-translate-y-1 transition-transform group">
          <div class="text-3xl mb-3">🕊️</div>
          <h3 class="text-lg mb-1 group-hover:text-accent transition-colors">A Year in the Psalms</h3>
          <p class="text-sm text-charcoal-light mb-3">A daily meditation through every Psalm with teaching, a theologian's voice, and space to sit with God.</p>
          <span class="text-xs font-sans text-charcoal-muted">730 days</span>
        </a>
        <a href="/verse-of-the-day/" class="card p-6 no-underline hover:-translate-y-1 transition-transform group">
          <div class="text-3xl mb-3">✦</div>
          <h3 class="text-lg mb-1 group-hover:text-accent transition-colors">Verse of the Day</h3>
          <p class="text-sm text-charcoal-light mb-3">One featured verse from every chapter, paired with a reflection to carry into your day.</p>
          <span class="text-xs font-sans text-charcoal-muted">1,189 verses</span>
        </a>
        <a href="/quotes/" class="card p-6 no-underline hover:-translate-y-1 transition-transform group">
          <div class="text-3xl mb-3">💬</div>
          <h3 class="text-lg mb-1 group-hover:text-accent transition-colors">Theologian Quotes</h3>
          <p class="text-sm text-charcoal-light mb-3">Real, sourced words from Spurgeon, Matthew Henry, J.C. Ryle, A.W. Pink, and 35 more.</p>
          <span class="text-xs font-sans text-charcoal-muted">100+ verified quotes</span>
        </a>
        <a href="/bible/genesis/1/" class="card p-6 no-underline hover:-translate-y-1 transition-transform group">
          <div class="text-3xl mb-3">🎧</div>
          <h3 class="text-lg mb-1 group-hover:text-accent transition-colors">Audio Bible</h3>
          <p class="text-sm text-charcoal-light mb-3">Listen to every chapter narrated with word-by-word highlighting. Follow along as you hear it read.</p>
          <span class="text-xs font-sans text-charcoal-muted">66 books</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="bg-cream-200 py-14">
    <div class="container-narrow text-center">
      <h2 class="mb-5">Our Mission</h2>
      <p class="text-xl text-charcoal-light leading-relaxed max-w-2xl mx-auto">
        To make the Bible freely accessible to every person — with the tools to read it, hear it, study it, and understand it. No subscriptions. No paywalls. Just Scripture, open to all.
      </p>
    </div>
  </section>

  <!-- Support -->
  <section class="py-16">
    <div class="container-narrow">
      <div class="bg-accent text-white rounded-2xl p-10 md:p-14 text-center">
        <h2 class="text-white mb-4">Pay It Forward</h2>
        <p class="text-lg text-white/80 max-w-lg mx-auto mb-8">
          Every page you read, every chapter you listen to — it's free because of people like you. Your gift puts Scripture in the hands of the next person who needs it.
        </p>
        <a href="/donate/#ways-to-give" class="inline-flex items-center justify-center px-8 py-3 bg-gold text-white rounded-lg text-lg font-serif tracking-wide hover:bg-gold-light transition-all duration-150 no-underline">
          Donate
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const picker = document.getElementById('book-picker') as HTMLSelectElement;
  const btn = document.getElementById('start-reading-btn') as HTMLAnchorElement;
  picker?.addEventListener('change', () => {
    btn.href = `/bible/${picker.value}/1/`;
  });

  // Show "Continue reading" if bookmark exists
  try {
    const saved = JSON.parse(localStorage.getItem('bible-bookmark') || '{}');
    if (saved.slug && saved.chapter) {
      const link = document.getElementById('continue-reading') as HTMLAnchorElement;
      const label = document.getElementById('continue-reading-label');
      if (link && label) {
        link.href = `/bible/${saved.slug}/${saved.chapter}/`;
        label.textContent = `Continue reading ${saved.name || saved.slug} ${saved.chapter}`;
        link.classList.remove('hidden');
        link.classList.add('inline-flex');
      }
    }
  } catch {}
</script>
