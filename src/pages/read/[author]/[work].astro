---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const authors = ['spurgeon', 'ryle', 'pink'];
  const paths: any[] = [];

  for (const authorSlug of authors) {
    const indexPath = path.join(process.cwd(), `public/data/library/${authorSlug}/_index.json`);
    const authorData = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));

    for (const work of authorData.works) {
      const workPath = path.join(process.cwd(), `public/data/library/${authorSlug}/${work.slug}.json`);
      const workData = JSON.parse(fs.readFileSync(workPath, 'utf-8'));

      paths.push({
        params: { author: authorSlug, work: work.slug },
        props: { authorData, workData, workMeta: work },
      });
    }
  }
  return paths;
}

const { authorData, workData, workMeta } = Astro.props;
const authorSlug = authorData.authorSlug;

// Wave SVG path (8 periods)
const wavePath = 'M 0 10 Q 8.5 0, 17 10 Q 25.5 20, 34 10 Q 42.5 0, 51 10 Q 59.5 20, 68 10 Q 76.5 0, 85 10 Q 93.5 20, 102 10 Q 110.5 0, 119 10 Q 127.5 20, 136 10 Q 144.5 0, 153 10 Q 161.5 20, 170 10 Q 178.5 0, 187 10 Q 195.5 20, 204 10 Q 212.5 0, 221 10 Q 229.5 20, 238 10 Q 246.5 0, 255 10 Q 263.5 20, 272 10';

function formatWords(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

// Build chapter data for JSON embedding
const chaptersJson = JSON.stringify(workData.chapters.map((ch: any, i: number) => ({
  title: ch.title,
  text: ch.text,
})));

const pageTitle = `Read: ${workData.title} by ${authorData.author} — The Table Bible`;
const pageDesc = `Read "${workData.title}" by ${authorData.author} in our e-reader. ${workMeta.chapters > 1 ? `${workMeta.chapters} chapters, ` : ''}${formatWords(workMeta.words)} words.`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Theologian Library", "item": "https://thetablebible.org/theologians/" },
    { "@type": "ListItem", "position": 2, "name": authorData.author, "item": `https://thetablebible.org/theologians/${authorSlug}/` },
    { "@type": "ListItem", "position": 3, "name": workData.title, "item": `https://thetablebible.org/read/${authorSlug}/${workMeta.slug}/` },
  ],
};

const articleUrl = `/theologians/${authorSlug}/${workMeta.slug}/`;
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={breadcrumbLd}>

  <!-- Reader navigation bar -->
  <div class="reader-bar">
    <div class="reader-bar__inner">
      <!-- Left: back to article page -->
      <div class="reader-bar__nav">
        <a href={articleUrl} class="reader-bar__link" aria-label="Back to article page">&larr;</a>
      </div>

      <!-- Center: chapter selector -->
      <div class="reader-bar__selectors">
        <span class="reader-bar__title">{workData.title}</span>
        {workData.chapters.length > 1 && (
          <select id="chapter-select" class="reader-bar__select reader-bar__select--ch" aria-label="Select chapter">
            {workData.chapters.map((ch: any, i: number) => (
              <option value={i}>{ch.title || `Chapter ${i + 1}`}</option>
            ))}
          </select>
        )}
      </div>

      <!-- Right: font size + reading mode controls -->
      <div class="reader-bar__nav">
        <button id="read-mode-toggle" class="reader-bar__mode-btn" aria-label="Toggle reading mode" title="Switch scroll / page mode">
          <svg id="mode-icon-scroll" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2" /><line x1="12" y1="2" x2="12" y2="22" /><line x1="8" y1="7" x2="10" y2="7" /><line x1="8" y1="11" x2="10" y2="11" /></svg>
          <svg id="mode-icon-page" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:none;"><line x1="5" y1="5" x2="19" y2="5" /><line x1="5" y1="9" x2="16" y2="9" /><line x1="5" y1="13" x2="19" y2="13" /><line x1="5" y1="17" x2="14" y2="17" /></svg>
        </button>
        <div id="page-nav" class="reader-bar__page-nav" style="display:none;">
          <button id="page-prev" class="reader-bar__page-btn" aria-label="Previous page">&lsaquo;</button>
          <span id="page-indicator" class="reader-bar__page-ind"></span>
          <button id="page-next" class="reader-bar__page-btn" aria-label="Next page">&rsaquo;</button>
        </div>
        <div class="reader-bar__font-controls">
          <button id="font-down" class="reader-bar__font-btn" aria-label="Decrease font size" title="Smaller text">A&minus;</button>
          <button id="font-up" class="reader-bar__font-btn" aria-label="Increase font size" title="Larger text">A+</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Book scene — open book photo with text overlays -->
  <div class="book-scene" id="book-body"
    data-work-slug={workMeta.slug}
    data-author-slug={authorSlug}
    data-work-title={workData.title}
    data-pagefind-body
    data-pagefind-meta={`type:E-Reader, title:${workData.title} by ${authorData.author}`}
    data-pagefind-filter="type:E-Reader">

    <!-- Book photograph (visible only on lg+) -->
    <img
      class="book-photo"
      src="/images/book-open-full.webp"
      alt=""
      draggable="false"
      loading="eager"
    />

    <!-- Aspect-ratio container matching the book image dimensions -->
    <div class="book-frame">

      <!-- ── LEFT PAGE ── Author + chapter list (lg+ only) -->
      <div class="book-left">
        <div class="book-page-inner">
          <div class="page-title" id="left-page-title">{authorData.author.split(' ').pop()?.toUpperCase()}</div>
          <svg class="page-wave" viewBox="0 0 272 20" preserveAspectRatio="none">
            <path d={wavePath} fill="none" stroke="#8B7355" stroke-width="3.2" />
          </svg>
          {workData.chapters.length > 1 ? (
            <nav class="ch-grid" aria-label="Chapter navigation">
              {workData.chapters.map((ch: any, i: number) => (
                <button
                  type="button"
                  class:list={['ch-pill', { 'ch-pill--active': i === 0 }]}
                  data-ch={i}
                  aria-label={ch.title || `Chapter ${i + 1}`}
                >
                  {i + 1}
                </button>
              ))}
            </nav>
          ) : (
            <div class="left-page-info">
              <p class="left-page-work-title">{workData.title}</p>
              <p class="left-page-meta">{formatWords(workMeta.words)} words</p>
            </div>
          )}
          <div class="page-xlinks">
            <a href={articleUrl} class="page-xlinks__pill">Article View</a>
            <a href={`/theologians/${authorSlug}/`} class="page-xlinks__pill">All Works</a>
          </div>
        </div>
      </div>

      <!-- ── RIGHT PAGE (desktop) / CARD (mobile) ── Reading text -->
      <div class="book-right">
        <div class="book-page-inner">
          <div class="page-title page-title--mobile">{workData.title}</div>
          <div class="page-title page-title--desktop" id="right-page-title">{workData.chapters[0]?.title || workData.title}</div>
          <svg class="page-wave" viewBox="0 0 272 20" preserveAspectRatio="none">
            <path d={wavePath} fill="none" stroke="#8B7355" stroke-width="3.2" />
          </svg>

          <div class="page-body" id="page-body">
            <div class="page-body__content" id="page-content">
              <!-- SSR: render first chapter for SEO / no-JS fallback -->
              {workData.chapters.length > 0 && (
                <Fragment>
                  {workData.chapters[0].text.split(/\n\n+/).map((para: string) =>
                    para.trim() ? <p class="bk-para">{para.trim()}</p> : null
                  )}
                </Fragment>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Page-turn arrows (page mode only) -->
    <button type="button" class="page-arrow page-arrow--prev" id="page-arrow-prev" aria-label="Previous page">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
    </button>
    <button type="button" class="page-arrow page-arrow--next" id="page-arrow-next" aria-label="Next page">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18" /></svg>
    </button>
  </div>

  <!-- Bottom navigation -->
  <nav class="ch-nav" aria-label="Book navigation">
    <div class="ch-nav__inner">
      <a href={articleUrl} class="ch-nav__link">
        <span>&larr;</span> Article View
      </a>
      <a href={`/theologians/${authorSlug}/`} class="ch-nav__center">All Works</a>
      <a href="/theologians/" class="ch-nav__link">
        Library <span>&rarr;</span>
      </a>
    </div>
  </nav>

  <!-- Chapter data for client-side rendering -->
  <script define:vars={{ chaptersJson, authorName: authorData.author, workTitle: workData.title }}>
    window.__BOOK_CHAPTERS = JSON.parse(chaptersJson);
    window.__BOOK_AUTHOR = authorName;
    window.__BOOK_TITLE = workTitle;
  </script>

</BaseLayout>

<!-- Client-side interactivity -->
<script>
  // ── Chapter data from SSR ──────────────────────────────
  const chapters: { title: string; text: string }[] = (window as any).__BOOK_CHAPTERS || [];
  const bookAuthor: string = (window as any).__BOOK_AUTHOR || '';
  const bookTitle: string = (window as any).__BOOK_TITLE || '';
  let currentChapter = 0;

  const chapterSelect = document.getElementById('chapter-select') as HTMLSelectElement | null;
  const bookBody = document.getElementById('book-body');
  const rightPageTitle = document.getElementById('right-page-title');

  // Right page: text flows top-to-bottom within this single page container.
  // Pagination via CSS multi-column within the right page only (same as Bible reader).
  const pageBody = document.getElementById('page-body') as HTMLElement | null;
  const pageContent = document.getElementById('page-content') as HTMLElement | null;

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderChapterContent(chIdx: number): string {
    const ch = chapters[chIdx];
    if (!ch) return '';
    const paras = ch.text.split(/\n\n+/).filter((p: string) => p.trim());
    let html = '';

    // First paragraph gets a drop cap
    if (paras.length > 0) {
      const first = paras[0].trim();
      const firstChar = first.charAt(0);
      const rest = first.slice(1);
      if (/[A-Za-z]/.test(firstChar)) {
        html += `<p class="bk-para bk-para--first"><span class="dc-wrap"><span class="dc-letter">${escapeHtml(firstChar.toUpperCase())}</span></span>${escapeHtml(rest)}</p>`;
      } else {
        html += `<p class="bk-para">${escapeHtml(first)}</p>`;
      }
      for (let i = 1; i < paras.length; i++) {
        html += `<p class="bk-para">${escapeHtml(paras[i].trim())}</p>`;
      }
    }

    return html;
  }

  function loadChapter(chIdx: number) {
    if (!pageContent) return;
    currentChapter = chIdx;

    pageContent.innerHTML = renderChapterContent(chIdx);

    // Update right page title
    const ch = chapters[chIdx];
    if (rightPageTitle) rightPageTitle.textContent = ch?.title || bookTitle;
    if (chapterSelect) chapterSelect.value = String(chIdx);

    // Update active chapter pill on left page
    document.querySelectorAll('.ch-pill').forEach((el, i) => {
      el.classList.toggle('ch-pill--active', i === chIdx);
    });

    if (currentMode === 'page') {
      currentPage = 0;
      requestAnimationFrame(() => requestAnimationFrame(() => {
        recalcPages();
        goToPage(0);
      }));
    } else {
      if (pageBody) pageBody.scrollTop = 0;
    }

    saveBookmark();
  }

  // Chapter select handler (toolbar dropdown)
  chapterSelect?.addEventListener('change', () => {
    const idx = parseInt(chapterSelect.value, 10);
    loadChapter(idx);
  });

  // Chapter pill click handler (left page grid)
  document.querySelectorAll('.ch-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      const idx = parseInt((pill as HTMLElement).dataset.ch || '0', 10);
      loadChapter(idx);
    });
  });

  // ── Font size control ──────────────────────────────────
  const FONT_STEPS = [0.95, 1.0, 1.1, 1.2, 1.35];
  const FONT_KEY = 'ereader-font-step';
  let fontStep = parseInt(localStorage.getItem(FONT_KEY) || '1', 10);
  if (fontStep < 0 || fontStep >= FONT_STEPS.length) fontStep = 1;

  function applyFontSize() {
    document.documentElement.style.setProperty('--font-scale', String(FONT_STEPS[fontStep]));
    localStorage.setItem(FONT_KEY, String(fontStep));
    if (currentMode === 'page') {
      requestAnimationFrame(() => requestAnimationFrame(() => {
        recalcPages();
        goToPage(currentPage);
      }));
    }
  }

  document.getElementById('font-down')?.addEventListener('click', () => {
    if (fontStep > 0) { fontStep--; applyFontSize(); }
  });
  document.getElementById('font-up')?.addEventListener('click', () => {
    if (fontStep < FONT_STEPS.length - 1) { fontStep++; applyFontSize(); }
  });

  // ── Reading mode: scroll vs. page ──────────────────────
  // Pagination uses same CSS multi-column approach as Bible reader:
  // - Set height on .page-body__content = container visible height
  // - Set column-width = container width -> one column = one "page"
  // - Navigate by translateX(-pageIndex * pageStride)
  // - overflow:hidden on .page-body clips to show one column at a time
  // - break-inside:avoid on .bk-para ensures paragraphs never split
  const MODE_KEY = 'ereader-read-mode';
  let currentMode: 'scroll' | 'page' = (localStorage.getItem(MODE_KEY) as any) || 'scroll';
  const modeToggle = document.getElementById('read-mode-toggle');
  const modeIconScroll = document.getElementById('mode-icon-scroll');
  const modeIconPage = document.getElementById('mode-icon-page');
  const pageNav = document.getElementById('page-nav');
  const pagePrev = document.getElementById('page-prev');
  const pageNext = document.getElementById('page-next');
  const pageInd = document.getElementById('page-indicator');

  let currentPage = 0;
  let totalPages = 1;
  let _colWidth = 0;
  let _pageStride = 0;

  function recalcPages() {
    if (!pageBody || !pageContent || currentMode !== 'page') return;

    // Reset column layout + transform so we can measure natural dimensions
    pageContent.style.transform = '';
    pageContent.style.columnWidth = '';
    pageContent.style.height = '';
    pageContent.style.columnGap = '';
    pageContent.style.columnFill = '';
    pageBody.style.height = '';
    void pageContent.offsetHeight;

    let colH = pageBody.clientHeight;

    // On mobile, .page-body has no fixed height. Set viewport-based height.
    if (colH <= 0 || colH >= pageContent.scrollHeight - 2) {
      const bodyRect = pageBody.getBoundingClientRect();
      const vh = window.visualViewport?.height || window.innerHeight;
      colH = Math.max(300, vh - bodyRect.top - 32);
      pageBody.style.height = colH + 'px';
    }

    _colWidth = pageContent.clientWidth;
    if (_colWidth <= 0) return;

    // column-gap must be > padding to prevent overflow columns bleeding
    // into the padding box (clipped area)
    const cs = getComputedStyle(pageBody);
    const padRight = parseFloat(cs.paddingRight) || 0;
    const gap = Math.ceil(padRight * 2 + 4);

    pageContent.style.height = colH + 'px';
    pageContent.style.columnWidth = _colWidth + 'px';
    pageContent.style.columnGap = gap + 'px';
    pageContent.style.columnFill = 'auto';

    void pageContent.scrollWidth;

    _pageStride = _colWidth + gap;
    totalPages = Math.max(1, Math.round((pageContent.scrollWidth + gap) / _pageStride));
    if (currentPage >= totalPages) currentPage = totalPages - 1;

    pageContent.style.transform = `translateX(-${currentPage * _pageStride}px)`;
    updatePageUI();
  }

  function updatePageUI() {
    if (pageInd) pageInd.textContent = `${currentPage + 1} / ${totalPages}`;
  }

  function goToPage(n: number) {
    const target = Math.max(0, Math.min(totalPages - 1, n));
    currentPage = target;
    if (pageContent && _pageStride > 0) {
      pageContent.style.transform = `translateX(-${currentPage * _pageStride}px)`;
    }
    updatePageUI();
    debouncedSaveBookmark();
  }

  function enterPageMode() {
    currentMode = 'page';
    localStorage.setItem(MODE_KEY, 'page');
    if (pageBody) {
      pageBody.classList.add('page-body--paged');
      pageBody.scrollTop = 0;
    }
    if (modeIconScroll) modeIconScroll.style.display = 'none';
    if (modeIconPage) modeIconPage.style.display = '';
    if (pageNav) pageNav.style.display = '';
    document.querySelectorAll('.page-arrow').forEach(el => (el as HTMLElement).style.display = 'flex');
    currentPage = 0;
    requestAnimationFrame(() => recalcPages());
  }

  function enterScrollMode() {
    currentMode = 'scroll';
    localStorage.setItem(MODE_KEY, 'scroll');
    if (pageBody) {
      pageBody.classList.remove('page-body--paged');
      pageBody.style.height = '';
    }
    if (pageContent) {
      pageContent.style.transform = '';
      pageContent.style.columnWidth = '';
      pageContent.style.height = '';
      pageContent.style.columnGap = '';
      pageContent.style.columnFill = '';
    }
    if (modeIconScroll) modeIconScroll.style.display = '';
    if (modeIconPage) modeIconPage.style.display = 'none';
    if (pageNav) pageNav.style.display = 'none';
    document.querySelectorAll('.page-arrow').forEach(el => (el as HTMLElement).style.display = 'none');
  }

  modeToggle?.addEventListener('click', () => {
    if (currentMode === 'scroll') enterPageMode();
    else enterScrollMode();
  });

  pagePrev?.addEventListener('click', () => goToPage(currentPage - 1));
  pageNext?.addEventListener('click', () => goToPage(currentPage + 1));

  const arrowPrev = document.getElementById('page-arrow-prev');
  const arrowNext = document.getElementById('page-arrow-next');
  arrowPrev?.addEventListener('click', () => goToPage(currentPage - 1));
  arrowNext?.addEventListener('click', () => goToPage(currentPage + 1));

  // ── Swipe navigation ───────────────────────────────────
  let touchStartX = 0;
  let touchStartY = 0;
  bookBody?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  bookBody?.addEventListener('touchend', (e) => {
    if (currentMode !== 'page') return;
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) < 50 || Math.abs(dx) < Math.abs(dy) * 1.5) return;
    if (dx < 0) goToPage(currentPage + 1);
    else goToPage(currentPage - 1);
  }, { passive: true });

  // ── Resize handler ─────────────────────────────────────
  let _resizeTimer = 0;
  function _onResize() {
    if (currentMode !== 'page') return;
    clearTimeout(_resizeTimer);
    _resizeTimer = window.setTimeout(() => {
      recalcPages();
      goToPage(currentPage);
    }, 150);
  }
  window.addEventListener('resize', _onResize);
  window.visualViewport?.addEventListener('resize', _onResize);

  // ── Keyboard shortcuts ─────────────────────────────────
  document.addEventListener('keydown', (e) => {
    const tag = (e.target as HTMLElement).tagName;
    if (tag === 'SELECT' || tag === 'INPUT' || tag === 'TEXTAREA') return;
    if (e.key === 'ArrowLeft') {
      if (currentMode === 'page' && currentPage > 0) goToPage(currentPage - 1);
    }
    if (e.key === 'ArrowRight') {
      if (currentMode === 'page' && currentPage < totalPages - 1) goToPage(currentPage + 1);
    }
  });

  // ── Reading position bookmark ──────────────────────────
  const BOOKMARK_KEY = 'ereader-bookmark';
  const _workSlug = bookBody?.dataset.workSlug || '';
  const _authorSlug = bookBody?.dataset.authorSlug || '';

  function saveBookmark() {
    const bk: Record<string, any> = {
      author: _authorSlug,
      work: _workSlug,
      chapter: currentChapter,
      mode: currentMode,
      ts: Date.now(),
    };
    if (currentMode === 'page') {
      bk.page = currentPage;
    } else if (pageBody) {
      bk.scrollTop = pageBody.scrollTop;
    }
    try { localStorage.setItem(BOOKMARK_KEY, JSON.stringify(bk)); } catch {}
  }

  let _bookmarkTimer = 0;
  function debouncedSaveBookmark() {
    clearTimeout(_bookmarkTimer);
    _bookmarkTimer = window.setTimeout(saveBookmark, 500);
  }

  pagePrev?.addEventListener('click', debouncedSaveBookmark);
  pageNext?.addEventListener('click', debouncedSaveBookmark);
  pageBody?.addEventListener('scroll', debouncedSaveBookmark, { passive: true });

  // ── Initialize ─────────────────────────────────────────
  applyFontSize();

  // Restore bookmark if returning to same work
  let startChapter = 0;
  let startPage = 0;
  let startScroll = 0;
  try {
    const saved = JSON.parse(localStorage.getItem(BOOKMARK_KEY) || '{}');
    if (saved.author === _authorSlug && saved.work === _workSlug) {
      startChapter = saved.chapter || 0;
      if (saved.mode === 'page') startPage = saved.page || 0;
      if (saved.mode === 'scroll') startScroll = saved.scrollTop || 0;
    }
  } catch {}

  loadChapter(startChapter);

  if (currentMode === 'page') {
    enterPageMode();
    if (startPage > 0) {
      requestAnimationFrame(() => requestAnimationFrame(() => {
        goToPage(startPage);
      }));
    }
  } else {
    enterScrollMode();
    if (startScroll > 0 && pageBody) {
      requestAnimationFrame(() => { pageBody.scrollTop = startScroll; });
    }
  }

  saveBookmark();
</script>

<!-- Styles — Theologian E-Reader (mirrors Bible reader two-page layout) -->
<style>
  /* ── Reader toolbar ─────────────────────────────────────── */
  .reader-bar {
    position: sticky;
    top: 0;
    z-index: 30;
    background: #1a1510;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
    padding: 0.4rem 0.75rem;
  }
  .reader-bar__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .reader-bar__nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .reader-bar__link {
    color: #C9A227;
    font-size: 1.1rem;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
    transition: background 0.15s;
  }
  .reader-bar__link:hover { background: rgba(201, 162, 39, 0.15); }
  .reader-bar__selectors {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    justify-content: center;
    min-width: 0;
  }
  .reader-bar__title {
    color: #f5f0e6;
    font-family: 'EB Garamond', serif;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }
  .reader-bar__select {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(139, 115, 85, 0.4);
    color: #f5f0e6;
    font-family: 'EB Garamond', serif;
    font-size: 0.9rem;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    cursor: pointer;
    max-width: 240px;
  }
