---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — The Table Bible" description="Learn about Come to the Table Ministries and our mission to make the World English Bible freely accessible to everyone.">
  <section class="about-hero">
    <div class="container container-narrow">
      <h1>About The Table Bible</h1>
      <div class="divider"></div>
      <p class="about-intro">
        To make the Bible freely accessible to every person through peaceful, 
        distraction-free video readings presented in a timeless book-on-table format 
        — always free to watch, download, and share.
      </p>
    </div>
  </section>
  
  <section class="about-story">
    <div class="container container-narrow">
      <h2>Our Story</h2>
      <p>
        The Table Bible began with a simple vision: what if reading the Bible could feel 
        like sitting down at a warm, welcoming table with Scripture open before you?
      </p>
      <p>
        In a world of distractions, we wanted to create a space where people could 
        engage with God's Word in a calm, focused environment. No flashy graphics, 
        no competing visuals — just the text itself, beautifully presented on the page 
        of an open book, with each word illuminating as it's read aloud.
      </p>
      <p>
        We chose the World English Bible because it's modern, easy to understand, 
        and completely in the public domain — meaning it can be freely shared with 
        anyone, anywhere, without restriction.
      </p>
    </div>
  </section>
  
  <section class="about-presentation">
    <div class="container container-narrow">
      <h2>The Presentation</h2>
      <div class="feature-grid">
        <div class="feature-item">
          <h3>Book on Table</h3>
          <p>
            Every video features an open Bible resting on a wooden table — 
            a timeless, grounded aesthetic that feels both traditional and inviting.
          </p>
        </div>
        <div class="feature-item">
          <h3>Word-by-Word Highlighting</h3>
          <p>
            As each word is spoken, it gently illuminates on the page, 
            making it easy to follow along and stay focused.
          </p>
        </div>
        <div class="feature-item">
          <h3>Calm Narration</h3>
          <p>
            The Scripture is read with a peaceful, measured pace — 
            no rushing, no dramatic performance, just clear delivery.
          </p>
        </div>
        <div class="feature-item">
          <h3>4K Quality</h3>
          <p>
            Text is rendered at 4K resolution for crystal-clear legibility 
            on any screen, from phones to large TVs.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <section class="about-ministry">
    <div class="container container-narrow">
      <h2>Come to the Table Ministries</h2>
      <p>
        The Table Bible is a project of Come to the Table Ministries — 
        a small ministry with a big mission: to remove every barrier 
        between people and Scripture.
      </p>
      <p>
        We believe:
      </p>
      <ul class="beliefs-list">
        <li>Scripture should be <strong>free</strong> — no paywalls, no subscriptions</li>
        <li>Scripture should be <strong>accessible</strong> — for readers, listeners, and visual learners alike</li>
        <li>Scripture should be <strong>shareable</strong> — free to download, copy, and distribute</li>
        <li>Scripture should be <strong>peaceful</strong> — presented without distraction or manipulation</li>
      </ul>
      <p>
        "Come to the Table" is our invitation. Whether you're a lifelong believer 
        or just curious about what the Bible actually says, you're welcome here.
      </p>
    </div>
  </section>
  
  <section id="public-domain" class="about-public-domain">
    <div class="container container-narrow">
      <h2>Public Domain</h2>
      <div class="pd-card">
        <h3>What is the World English Bible?</h3>
        <p>
          The World English Bible (WEB) is a modern English translation of the Bible 
          that is completely in the <strong>public domain</strong>. This means:
        </p>
        <ul>
          <li>No copyright restrictions</li>
          <li>Free to copy, quote, and distribute</li>
          <li>No permission required</li>
          <li>Can be used for any purpose, commercial or non-commercial</li>
        </ul>
        <p>
          The WEB is based on the American Standard Version of 1901, 
          with updates for modern language and readability. It includes 
          the Old Testament, New Testament, and Apocrypha.
        </p>
      </div>
      
      <div class="pd-card">
        <h3>Can I Use Your Videos?</h3>
        <p>
          <strong>Yes!</strong> All Table Bible videos are free to:
        </p>
        <ul>
          <li>Watch and share</li>
          <li>Download for offline use</li>
          <li>Use in church services</li>
          <li>Include in your own projects</li>
          <li>Share on social media</li>
        </ul>
        <p>
          We only ask that you credit "The Table Bible" when sharing, 
          though even this is not legally required.
        </p>
      </div>
    </div>
  </section>
  
  <section class="about-contact-cta">
    <div class="container container-narrow">
      <div class="cta-card">
        <h2>Get in Touch</h2>
        <p>Have questions, suggestions, or just want to say hello?</p>
        <a href="/contact/" class="btn btn-primary">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── About Hero ──────────────────────────────────────────────────── */
  .about-hero {
    padding: var(--space-4xl) 0;
    text-align: center;
    background: var(--bg-secondary);
  }
  
  .about-hero h1 {
    margin-bottom: var(--space-lg);
  }
  
  .about-intro {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* ── Story Section ───────────────────────────────────────────────── */
  .about-story {
    padding: var(--space-4xl) 0;
  }
  
  .about-story h2 {
    margin-bottom: var(--space-xl);
  }
  
  .about-story p {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.8;
  }
  
  /* ── Presentation Section ────────────────────────────────────────── */
  .about-presentation {
    padding: var(--space-4xl) 0;
    background: var(--bg-secondary);
  }
  
  .about-presentation h2 {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }
  
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-xl);
  }
  
  .feature-item {
    padding: var(--space-lg);
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(201, 168, 106, 0.1);
  }
  
  .feature-item h3 {
    font-size: 1.125rem;
    color: var(--gold-light);
    margin-bottom: var(--space-md);
  }
  
  .feature-item p {
    color: var(--text-muted);
    font-size: 0.9375rem;
    margin: 0;
    line-height: 1.6;
  }
  
  /* ── Ministry Section ────────────────────────────────────────────── */
  .about-ministry {
    padding: var(--space-4xl) 0;
  }
  
  .about-ministry h2 {
    margin-bottom: var(--space-xl);
  }
  
  .about-ministry p {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.8;
  }
  
  .beliefs-list {
    list-style: none;
    margin: var(--space-xl) 0;
    display: grid;
    gap: var(--space-md);
  }
  
  .beliefs-list li {
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-card);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--gold-light);
    font-size: 1.0625rem;
    color: var(--cream);
  }
  
  .beliefs-list strong {
    color: var(--gold-light);
  }
  
  /* ── Public Domain Section ───────────────────────────────────────── */
  .about-public-domain {
    padding: var(--space-4xl) 0;
    background: var(--bg-secondary);
    scroll-margin-top: 100px;
  }
  
  .about-public-domain h2 {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }
  
  .pd-card {
    padding: var(--space-xl);
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(201, 168, 106, 0.1);
    margin-bottom: var(--space-xl);
  }
  
  .pd-card:last-child {
    margin-bottom: 0;
  }
  
  .pd-card h3 {
    font-size: 1.25rem;
    color: var(--gold-light);
    margin-bottom: var(--space-lg);
  }
  
  .pd-card p {
    color: var(--text-muted);
    line-height: 1.7;
  }
  
  .pd-card ul {
    list-style: none;
    margin: var(--space-lg) 0;
    display: grid;
    gap: var(--space-sm);
  }
  
  .pd-card li {
    padding-left: var(--space-lg);
    position: relative;
    color: var(--cream);
  }
  
  .pd-card li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--gold);
  }
  
  /* ── Contact CTA ─────────────────────────────────────────────────── */
  .about-contact-cta {
    padding: var(--space-4xl) 0;
  }
  
  .cta-card {
    text-align: center;
    padding: var(--space-3xl);
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(201, 168, 106, 0.1);
  }
  
  .cta-card h2 {
    margin-bottom: var(--space-md);
  }
  
  .cta-card p {
    color: var(--text-muted);
    margin-bottom: var(--space-xl);
  }
</style>
