---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllTtbEntries, getBookSlug, getDevotionalUrl } from '../../../utils/devotional';

const entries = getAllTtbEntries();

// Group by book for the browse view
const bookGroups = new Map<string, { name: string; slug: string; chapters: typeof entries }>();
for (const entry of entries) {
  const slug = getBookSlug(entry.book);
  const group = bookGroups.get(slug) || { name: entry.book_name, slug, chapters: [] };
  group.chapters.push(entry);
  bookGroups.set(slug, group);
}

const title = "Daily Devotional Archive";
const description = "Browse every chapter of the Bible with verse-by-verse teaching, theologian quotes, and reflection questions. Hear it. Read it. Understand it.";
---
<BaseLayout title={title} description={description}>
  <main class="container-page py-12">
    <header class="mb-12 text-center">
      <h1 class="text-4xl mb-3">Daily Devotional</h1>
      <p class="text-lg text-charcoal-muted max-w-[600px] mx-auto">
        Walk through the Bible one chapter at a time. Each entry features a focused passage, 
        teaching from Scripture, a theologian's insight, and a question to carry with you.
      </p>
    </header>

    <section class="grid gap-8">
      {[...bookGroups.values()].map(group => (
        <div>
          <h2 class="text-2xl mb-4 border-b border-cream-300 pb-2">{group.name}</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
            {group.chapters.map(entry => (
              <a
                href={getDevotionalUrl(group.slug, entry.chapter)}
                class="card px-4 py-3 text-center hover:border-gold transition-colors"
              >
                <span class="block text-sm text-charcoal-muted">Chapter {entry.chapter}</span>
                <span class="block text-xs text-charcoal-muted mt-1 line-clamp-2">{entry.hook || entry.title || ''}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>
</BaseLayout>
