---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const authors = ['spurgeon', 'ryle', 'pink'];
  const paths: any[] = [];

  for (const authorSlug of authors) {
    const indexPath = path.join(process.cwd(), `public/data/library/${authorSlug}/_index.json`);
    const authorData = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));

    for (const work of authorData.works) {
      const workPath = path.join(process.cwd(), `public/data/library/${authorSlug}/${work.slug}.json`);
      const workData = JSON.parse(fs.readFileSync(workPath, 'utf-8'));

      paths.push({
        params: { author: authorSlug, work: work.slug },
        props: {
          authorData,
          workData,
          workMeta: work,
        },
      });
    }
  }
  return paths;
}

const { authorData, workData, workMeta } = Astro.props;
const authorSlug = authorData.authorSlug;
const isSingleChapter = workData.chapters.length === 1;
const isLargeText = workMeta.words > 80000;

function formatWords(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

const pageTitle = `${workData.title} by ${authorData.author} — The Table Bible`;
const pageDesc = `Read "${workData.title}" by ${authorData.author} free online. ${workMeta.chapters > 1 ? `${workMeta.chapters} chapters, ` : ''}${formatWords(workMeta.words)} words.`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `https://thetablebible.org/theologians/${authorSlug}/${workMeta.slug}/#breadcrumb`,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Theologian Library", "item": "https://thetablebible.org/theologians/" },
    { "@type": "ListItem", "position": 2, "name": authorData.author, "item": `https://thetablebible.org/theologians/${authorSlug}/` },
    { "@type": "ListItem", "position": 3, "name": workData.title, "item": `https://thetablebible.org/theologians/${authorSlug}/${workMeta.slug}/` },
  ],
};

const bookLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": workData.title,
  "author": { "@type": "Person", "name": authorData.author },
  "inLanguage": "en",
  "url": `https://thetablebible.org/theologians/${authorSlug}/${workMeta.slug}/`,
  "publisher": { "@type": "Organization", "name": "The Table Bible", "url": "https://thetablebible.org" },
};
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={[breadcrumbLd, bookLd]}>
  <article class="reader-page">
    <p class="reader-back">
      <a href={`/theologians/${authorSlug}/`}>&larr; {authorData.author}</a>
    </p>
    <header class="reader-header parchment-card parchment-card--centered">
      <h1 class="reader-title">{workData.title}</h1>
      <p class="reader-author">by {authorData.author}</p>
      <p class="reader-meta">{workMeta.chapters > 1 ? `${workMeta.chapters} chapters · ` : ''}{formatWords(workMeta.words)} words</p>
      <a href={`/read/${authorSlug}/${workMeta.slug}/`} class="reader-ereader-btn">Open in E-Reader</a>
    </header>

    {/* Multi-chapter: Table of Contents */}
    {!isSingleChapter && (
      <nav class="reader-toc">
        <h2 class="reader-toc__heading">Contents</h2>
        <ol class="reader-toc__list">
          {workData.chapters.map((ch: any, i: number) => (
            <li>
              <a href={`/theologians/${authorSlug}/${workMeta.slug}/${i + 1}/`} class="reader-toc__link">
                <span class="reader-toc__title">{ch.title}</span>
                <span class="reader-toc__words">{formatWords(ch.text.split(' ').length)}</span>
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    {/* Single chapter: render text inline (or lazy-load for large texts) */}
    {isSingleChapter && !isLargeText && (
      <div class="reader-body">
        {workData.chapters[0].text.split('\n\n').map((para: string) => (
          <p>{para}</p>
        ))}
      </div>
    )}

    {/* Single chapter but very large: client-side paginated reading */}
    {isSingleChapter && isLargeText && (
      <div class="reader-body" id="reader-body">
        <div class="reader-loading">
          <p>Loading text...</p>
        </div>
      </div>
    )}

    {isSingleChapter && (
      <nav class="reader-nav-bottom">
        <a href={`/theologians/${authorSlug}/`} class="reader-nav__link">&larr; All works by {authorData.author}</a>
      </nav>
    )}
  </article>
</BaseLayout>

{isSingleChapter && isLargeText && (
  <script define:vars={{ dataUrl: `/data/library/${authorSlug}/${workMeta.slug}.json` }}>
    (function() {
      const PAGE_SIZE = 200; // paragraphs per page
      const body = document.getElementById('reader-body');
      if (!body) return;

      fetch(dataUrl)
        .then(r => r.json())
        .then(data => {
          const text = data.chapters[0].text;
          const paragraphs = text.split('\n\n').filter(p => p.trim());
          const totalPages = Math.ceil(paragraphs.length / PAGE_SIZE);
          let currentPage = 0;

          function renderPage(page) {
            const start = page * PAGE_SIZE;
            const end = Math.min(start + PAGE_SIZE, paragraphs.length);
            const html = paragraphs.slice(start, end)
              .map(p => '<p>' + p.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>')
              .join('');

            let nav = '';
            if (totalPages > 1) {
              nav = '<div class="reader-pagination">';
              if (page > 0) nav += '<button class="reader-page-btn" data-page="' + (page - 1) + '">&larr; Previous</button>';
              nav += '<span class="reader-page-info">Page ' + (page + 1) + ' of ' + totalPages + '</span>';
              if (page < totalPages - 1) nav += '<button class="reader-page-btn" data-page="' + (page + 1) + '">Next &rarr;</button>';
              nav += '</div>';
            }

            body.innerHTML = html + nav;

            body.querySelectorAll('.reader-page-btn').forEach(btn => {
              btn.addEventListener('click', () => {
                const p = parseInt(btn.getAttribute('data-page'));
                currentPage = p;
                renderPage(p);
                body.scrollIntoView({ behavior: 'smooth' });
              });
            });
          }

          renderPage(0);
        })
        .catch(() => {
          body.innerHTML = '<p>Failed to load text. Please try refreshing the page.</p>';
        });
    })();
  </script>
)}

<style>
  .reader-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  .reader-header { text-align: center; margin-bottom: 2.5rem; padding: 2rem 1.5rem; }
  .reader-back { margin: 0 0 1rem; }
  .reader-back a {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #6B4226;
    text-decoration: none;
    transition: color 0.15s;
  }
  .reader-back a:hover { color: #C9A227; }
  .reader-title {
    font-family: 'EB Garamond', serif;
    font-size: 2rem;
    color: #2A2520;
    margin: 0 0 0.25rem;
    line-height: 1.2;
  }
  .reader-author {
    font-family: 'EB Garamond', serif;
    font-size: 1.1rem;
    color: #5A5A6A;
    margin: 0 0 0.25rem;
  }
  .reader-meta {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #7A7A8A;
    margin: 0;
  }
  .reader-ereader-btn {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.45rem 1.25rem;
    font-family: 'EB Garamond', serif;
    font-size: 0.95rem;
    color: #6B0F1A;
    background: rgba(201, 162, 39, 0.5);
    border: 2px solid #C9A227;
    border-radius: 99px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .reader-ereader-btn:hover {
    background: rgba(201, 162, 39, 0.75);
    color: #2A2520;
  }

  /* Table of Contents */
  .reader-toc { margin-bottom: 2rem; }
  .reader-toc__heading {
    font-family: 'EB Garamond', serif;
    font-size: 1.3rem;
    color: #6B4226;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(107, 66, 38, 0.15);
  }
  .reader-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: toc;
  }
  .reader-toc__list li { counter-increment: toc; }
  .reader-toc__link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .reader-toc__link:hover { background: rgba(201, 162, 39, 0.08); }
  .reader-toc__link::before {
    content: counter(toc) ".";
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #7A7A8A;
    min-width: 2rem;
    flex-shrink: 0;
  }
  .reader-toc__title {
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem;
    color: #2A2520;
    flex: 1;
  }
  .reader-toc__words {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: #7A7A8A;
    margin-left: 1rem;
    white-space: nowrap;
  }

  /* Reading body */
  .reader-body {
    font-family: 'EB Garamond', serif;
    font-size: 1.12rem;
    line-height: 1.75;
    color: #2A2520;
  }
  .reader-body p {
    margin: 0 0 1.25rem;
    text-indent: 0;
  }
  .reader-loading {
    text-align: center;
    padding: 3rem 0;
    color: #7A7A8A;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
  }

  /* Pagination controls */
  :global(.reader-pagination) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 2rem 0 1rem;
    border-top: 1px solid rgba(107, 66, 38, 0.12);
    margin-top: 2rem;
  }
  :global(.reader-page-btn) {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #6B4226;
    background: transparent;
    border: 1px solid rgba(107, 66, 38, 0.2);
    border-radius: 6px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  :global(.reader-page-btn:hover) {
    background: rgba(201, 162, 39, 0.08);
    border-color: #C9A227;
  }
  :global(.reader-page-info) {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #7A7A8A;
  }

  .reader-nav-bottom {
    padding: 2rem 0 0;
    border-top: 1px solid rgba(107, 66, 38, 0.12);
    margin-top: 2rem;
    text-align: center;
  }
  .reader-nav__link {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #6B4226;
    text-decoration: none;
    transition: color 0.15s;
  }
  .reader-nav__link:hover { color: #C9A227; }

  [data-theme="dark"] .reader-title { color: #E4E2DC; }
  [data-theme="dark"] .reader-author { color: #B0AEA6; }
  [data-theme="dark"] .reader-back a { color: #C9A227; }
  [data-theme="dark"] .reader-toc__heading { color: #C9A227; border-bottom-color: rgba(201, 162, 39, 0.2); }
  [data-theme="dark"] .reader-toc__link:hover { background: rgba(201, 162, 39, 0.06); }
  [data-theme="dark"] .reader-toc__title { color: #E4E2DC; }
  [data-theme="dark"] .reader-body { color: #D8D4CC; }
  [data-theme="dark"] .reader-nav-bottom { border-top-color: rgba(201, 162, 39, 0.15); }
  [data-theme="dark"] .reader-nav__link { color: #C9A227; }
  [data-theme="dark"] :global(.reader-pagination) { border-top-color: rgba(201, 162, 39, 0.15); }
  [data-theme="dark"] :global(.reader-page-btn) { color: #C9A227; border-color: rgba(201, 162, 39, 0.2); }
  [data-theme="dark"] :global(.reader-page-btn:hover) { background: rgba(201, 162, 39, 0.06); }
</style>
