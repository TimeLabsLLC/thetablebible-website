---
/**
 * A subtle donate CTA banner shown at the bottom of content pages.
 * Compact, non-intrusive, and consistent across all surfaces.
 */
---
<aside class="donate-banner" data-pagefind-ignore>
  <p class="donate-banner__text">
    This content remains free because of generous givers like you.
  </p>
  <a href="/donate/#ways-to-give" class="donate-banner__btn donate-banner__btn--primary">
    Donate
  </a>
</aside>

<style>
  .donate-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px 24px;
    margin: 2.5rem 0 1rem;
    padding: 16px 24px;
    background: var(--gold-50);
    border: 1px solid var(--gold-light);
    border-radius: 12px;
    text-align: center;
  }
  .donate-banner__text {
    margin: 0;
    font-size: 14px;
    color: var(--charcoal-muted);
  }
  .donate-banner__btn {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 500;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .donate-banner__btn--primary {
    background: var(--gold);
    color: white;
  }
  .donate-banner__btn--primary:hover {
    background: var(--gold-light);
  }

</style>
