---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  jsonLd?: object | object[];
  robots?: string;
}

const { 
  title, 
  description = "The entire World English Bible, read aloud with word-by-word highlighting. Always free to watch, download, and share.",
  image = "/images/banner_2560x1440.png",
  jsonLd,
  robots = "index,follow",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalURL.href} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Table Bible" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:image" content={imageURL.href} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageURL.href} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600&family=UnifrakturMaguntia&display=swap" rel="stylesheet" />
  
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "The Table Bible",
    "url": "https://thetablebible.org",
    "logo": "https://thetablebible.org/images/profile_800x800.png",
    "description": "The entire World English Bible, read aloud with word-by-word highlighting. Always free to watch, download, and share.",
    "sameAs": ["https://youtube.com/@thetablebibleorg"]
  })} />
  {jsonLdItems.map(item => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))}
  
  <title>{title}</title>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  
  <header class="site-header">
    <nav class="nav container">
      <a href="/" class="nav-brand">
        <div class="brand-initial">T</div>
        <span class="brand-text">The Table Bible</span>
      </a>
      
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/library/">Library</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/donate/" class="nav-donate">Donate</a></li>
      </ul>
    </nav>
  </header>
  
  <main id="main-content">
    <slot />
  </main>
  
  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <div class="brand-initial">T</div>
            <span>The Table Bible</span>
          </a>
          <p class="footer-tagline">"Come to the Table."</p>
          <p class="footer-ministry">A ministry of Come to the Table Ministries</p>
        </div>
        
        <div class="footer-links">
          <div class="footer-column">
            <h4>Watch</h4>
            <ul>
              <li><a href="https://youtube.com/@thetablebibleorg" target="_blank" rel="noopener">YouTube Channel</a></li>
              <li><a href="/library/">Book Library</a></li>
            </ul>
          </div>
          
          <div class="footer-column">
            <h4>Learn More</h4>
            <ul>
              <li><a href="/about/">About Us</a></li>
              <li><a href="/about/#about-the-web">About the WEB</a></li>
              <li><a href="/contact/">Contact</a></li>
            </ul>
          </div>
          
          <div class="footer-column">
            <h4>Support</h4>
            <ul>
              <li><a href="/donate/">Donate</a></li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>Text: World English Bible (WEB) — Public Domain</p>
        <p>&copy; {new Date().getFullYear()} Come to the Table Ministries. All content free to share.</p>
      </div>
    </div>
  </footer>
  
  <script>
    // Mobile navigation toggle
    const navToggle = document.querySelector('.nav-toggle');
    const navLinks = document.querySelector('.nav-links');
    
    navToggle?.addEventListener('click', () => {
      const expanded = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', (!expanded).toString());
      navLinks?.classList.toggle('active');
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ── Skip Link ───────────────────────────────────────────────────── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    padding: var(--space-md) var(--space-lg);
    background: var(--gold);
    color: var(--espresso);
    border-radius: var(--radius-md);
    z-index: 1000;
    transition: top var(--transition-fast);
  }
  
  .skip-link:focus {
    top: var(--space-md);
  }
  
  /* ── Header ──────────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26, 22, 18, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(201, 168, 106, 0.1);
  }
  
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  
  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
  }
  
  .brand-initial {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: linear-gradient(145deg, var(--gold), var(--gold-dark));
    border-radius: 6px;
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 700;
    color: var(--crimson);
    line-height: 1;
  }
  
  .brand-text {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--cream);
    letter-spacing: 0.02em;
  }
  
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }
  
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--cream);
    transition: all var(--transition-fast);
  }
  
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    list-style: none;
  }
  
  .nav-links a {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    transition: color var(--transition-fast);
  }
  
  .nav-links a:hover {
    color: var(--cream);
  }
  
  .nav-donate {
    padding: var(--space-sm) var(--space-lg);
    background: transparent;
    border: 1px solid var(--gold-light);
    border-radius: var(--radius-md);
    color: var(--gold-light) !important;
  }
  
  .nav-donate:hover {
    background: rgba(201, 168, 106, 0.1);
    color: var(--gold) !important;
  }
  
  /* ── Footer ──────────────────────────────────────────────────────── */
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid rgba(201, 168, 106, 0.1);
    padding: var(--space-4xl) 0 var(--space-2xl);
  }
  
  .footer-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }
  
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--cream);
    font-family: var(--font-serif);
    font-size: 1.25rem;
  }
  
  .footer-logo .brand-initial {
    width: 36px;
    height: 36px;
    font-size: 20px;
  }
  
  .footer-tagline {
    font-style: italic;
    color: var(--gold-light);
    margin: 0;
  }
  
  .footer-ministry {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }
  
  .footer-column h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-light);
    margin-bottom: var(--space-md);
  }
  
  .footer-column ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  
  .footer-column a {
    font-size: 0.9375rem;
    color: var(--text-muted);
  }
  
  .footer-column a:hover {
    color: var(--cream);
  }
  
  .footer-bottom {
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(201, 168, 106, 0.1);
    text-align: center;
  }
  
  .footer-bottom p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: var(--space-xs) 0;
  }
  
  /* ── Mobile Responsive ───────────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }
    
    .nav-links {
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(26, 22, 18, 0.98);
      border-bottom: 1px solid rgba(201, 168, 106, 0.1);
      max-height: 0;
      overflow: hidden;
      transition: max-height var(--transition-base);
    }
    
    .nav-links.active {
      max-height: 400px;
    }
    
    .nav-links li {
      width: 100%;
    }
    
    .nav-links a {
      display: block;
      padding: var(--space-md) var(--space-lg);
      border-bottom: 1px solid rgba(201, 168, 106, 0.05);
    }
    
    .nav-donate {
      margin: var(--space-md) var(--space-lg);
      text-align: center;
    }
    
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }
    
    .brand-text {
      display: none;
    }
  }
  
  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
